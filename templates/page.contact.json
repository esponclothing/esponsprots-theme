      "settings": {
        "content_direction": "column",
        "gap": 16,
        "padding-block-start": 60,
        "padding-block-end": 20
      }
    },
    "form": {
      "type": "section",
      "blocks": {
        "contact_form": {
          "type": "contact-form",
          "settings": {
            "width": "custom",
            "custom_width": 60,
            "width_mobile": "custom",
            "custom_width_mobile": 100
