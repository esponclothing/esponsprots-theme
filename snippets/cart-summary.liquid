{%- doc -%}
  Renders the cart summary totals.

  @param {string} [accelerated_checkout_buttons_layout] - { 'vertical' } Forced layout of the additional checkout buttons, instead of relying on platform's layout.
  @param {string} [section_id] - The section ID for cart discount component.
{%- enddoc -%}

<div class="cart-totals">
  {% # We need to keep this node in place to allow morphing to work properly # %}
  <div class="cart-totals__original-container cart-primary-typography">
    {%- if cart.cart_level_discount_applications.size > 0 -%}
      <span class="cart-totals__item cart-totals__original">
        <span class="cart-totals__original-label">{{ 'content.cart_subtotal' | t }}</span>
        <span
          class="cart-totals__original-value cart-secondary-typography"
          data-testid="cart-subtotal-value"
        >
          {{- cart.items_subtotal_price | money -}}
        </span>
      </span>
      <ul
  class="cart-discounts"
  role="list"
  aria-label="Coupon Codes"
>
        {%- for discount in cart.cart_level_discount_applications -%}
          <li class="cart-discounts__item">
            <span class="cart-discounts__label">
              {{- 'icon-discount.svg' | inline_asset_content -}}
              {{ discount.title | escape }}
            </span>
            <span class="cart-discounts__value cart-secondary-typography"
              >-{{ discount.total_allocated_amount | money -}}
            </span>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

  {% if settings.show_cart_note or settings.show_add_discount_code %}
    <div class="cart-actions">
      {% if settings.show_cart_note %}
        <script
          type="module"
          src="{{ 'cart-note.js' | asset_url }}"
        ></script>

        <cart-note style="display: flex;">
          <accordion-custom
            class="cart-note"
            {% if settings.cart_note_open_by_default %}
              open-by-default-on-desktop
              open-by-default-on-mobile
            {% endif %}
          >
            <details
              class="details"
              {% if settings.cart_note_open_by_default %}
                open
              {% endif %}
            >
              <summary class="cart-note__summary">
                <span class="cart-note__label cart-primary-typography">
                  {{ 'content.seller_note' | t }}
                </span>

                <span class="cart-totals__icon">
                  {{- 'icon-plus.svg' | inline_asset_content -}}
                </span>
              </summary>

              <div class="details-content cart-note__inner">
                <label
                  for="cart-note"
                  class="visually-hidden"
                >
                  {{- 'content.seller_note' | t -}}
                </label>
                <textarea
                  form="cart-form"
                  on:input="/updateCartNote"
                  id="cart-note"
                  class="cart-note__instructions"
                  name="note"
                >{{ cart.note }}</textarea>
              </div>
            </details>
          </accordion-custom>
        </cart-note>
      {% endif %}
      {% if settings.show_cart_note and settings.show_add_discount_code %}
        <div class="cart-actions__divider"></div>
      {% endif %}
      {% if settings.show_add_discount_code %}
        {% liquid
          assign discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
          for item in cart.items
            for allocation in item.line_level_discount_allocations
              if allocation.discount_application.type == 'discount_code'
                assign discount_codes = item.line_level_discount_allocations | slice: forloop.index0 | map: 'discount_application' | map: 'title' | concat: discount_codes
              endif
            endfor
          endfor

          assign discount_codes = discount_codes | uniq

          # Evaluate the boolean expression for the disclosure state
          if discount_codes.size == 0
            assign disclosure_expanded = false
          else
            assign disclosure_expanded = true
          endif
        %}

        <accordion-custom class="cart-discount">
          <details
            class="details"
            {% if disclosure_expanded %}
              open
            {% endif %}
          >
            <summary class="cart-discount__summary">
              <span class="cart-discount__label cart-primary-typography">Coupon Code</span>

              <span class="cart-totals__icon">
                {{- 'icon-plus.svg' | inline_asset_content -}}
              </span>
            </summary>

            <div class="details-content">
              <div id="cart-discount-disclosure">
                <cart-discount-component
                  {% if section_id != blank %}
                    data-section-id="{{ section_id }}"
                  {% endif %}
                >
                  <div class="cart-discount__content">
                    <form
                      on:submit="/applyDiscount"
                      onsubmit="return false;"
                      class="cart-discount__form"
                    >
                      <label
                        for="cart-discount"
                        class="visually-hidden"
                      >
                        {{- 'accessibility.discount' | t -}}
                      </label>
                      <input
  id="cart-discount"
  class="cart-discount__input"
  type="text"
  name="discount"
  size="8"
  placeholder="Coupon Code"
  required
>
                      <button
  type="submit"
  class="button cart-discount__button"
>
  Apply Coupon Code
</button>
                    </form>
                  </div>
                  <div
                    class="cart-discount__error hidden"
                    role="alert"
                    ref="cartDiscountError"
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-error.svg' | inline_asset_content -}}
                    </span>
                    <small
                      class="cart-discount__error-text cart-primary-typography hidden"
                      ref="cartDiscountErrorDiscountCode"
                    >
                      {{ 'content.discount_code_error' | t: code: 'test' }}
                    </small>
                    <small
                      class="cart-discount__error-text cart-primary-typography hidden"
                      ref="cartDiscountErrorShipping"
                    >
                      {{ 'content.shipping_discount_error' | t }}
                    </small>
                  </div>
                  <ul class="cart-discount__codes">
                    {% for discount_code in discount_codes %}
                      <li
                        class="cart-discount__pill"
                        data-discount-code="{{ discount_code }}"
                        aria-label="{{ 'accessibility.discount_applied' | t: code: discount_code }}"
                      >
                        <p class="cart-discount__pill-code">
                          {{ discount_code }}
                        </p>
                        <button
                          type="button"
                          on:click="/removeDiscount"
                          class="cart-discount__pill-remove svg-wrapper svg-wrapper--smaller button-unstyled"
                          aria-label="{{ 'actions.remove_discount' | t: code: discount_code }}"
                        >
                          {{- 'icon-filters-close.svg' | inline_asset_content -}}
                        </button>
                      </li>
                    {% endfor %}
                  </ul>
                </cart-discount-component>
              </div>
            </div>
          </details>
        </accordion-custom>
      {% endif %}
    </div>
  {% endif %}

  {%- liquid
    # ---------------------------------------------------------
    # FIX: MANUALLY CALCULATE TRUE TOTAL TO IGNORE PARTIAL COD
    # ---------------------------------------------------------
    assign true_total = 0
    for item in cart.items
      assign line_item_price = item.variant.price | times: item.quantity
      assign true_total = true_total | plus: line_item_price
    endfor

    if settings.currency_code_enabled_cart_total
      assign total_price = true_total | money_with_currency
    else
      assign total_price = true_total | money
    endif
  -%}
  <div class="cart-totals__container{% if settings.show_installments %} cart-totals__container--has-installments{% endif %}">
    <span
      class="cart-totals__item cart-totals__total"
      role="status"
    >
      <span class="cart-totals__total-label cart-primary-typography">{{ 'content.cart_estimated_total' | t }}</span>
      <text-component
        ref="cartTotal"
        value="{{ total_price | strip_html }}"
        class="cart-totals__total-value cart-secondary-typography"
        {% comment %} Used by payment_terms web component {% endcomment %}
        data-testid="cart-total-value"
        data-cart-subtotal
      >
        {{ total_price }}
      </text-component>
    </span>
    {% if settings.show_installments %}
      <span class="cart-totals__item cart-totals__installments">
        {% form 'cart', cart %}
          {{ form | payment_terms }}
        {% endform %}
      </span>
    {% endif %}
    <div class="cart-totals__item cart-totals__tax-note cart-primary-typography">
      {% render 'tax-info', has_discounts_enabled: settings.show_add_discount_code %}
    </div>

    {%- if true_total > 0 -%}
      {%- assign cart_cashback = true_total | times: 5 | divided_by: 10000 -%}
      <div style="margin-top: 15px; padding: 15px; background: #eff6ff; border: 1px solid #3b82f6; border-radius: 8px; font-weight: bold; font-size: 15px; color: #1e3a8a; display: flex; align-items: center; gap: 10px; text-align: left;">
        <span style="font-size: 22px;">💰</span>
        <span>You will receive <strong>₹{{ cart_cashback }}</strong> cashback as Store Credit on this order!</span>
      </div>
    {%- endif -%}
  </div>
</div>

{% assign spin_reward_vid = cart.attributes.spin_reward_vid | plus: 0 %}
{% assign spin_min_order = cart.attributes.spin_min_order | plus: 0 %}
{% assign spin_min_order_paise = spin_min_order | times: 100 %}
{% assign has_prize = false %}
{% for item in cart.items %}
  {% if item.variant_id == spin_reward_vid %}
    {% assign has_prize = true %}
  {% endif %}
{% endfor %}

{% assign lock_checkout = false %}
{% if has_prize and cart.total_price < spin_min_order_paise %}
  {% assign lock_checkout = true %}
{% endif %}

<div class="cart__ctas">
  {% if lock_checkout %}
    <div style="background:#fef2f2; color:#b91c1c; padding:12px; border-radius:6px; font-size:13px; font-weight: 600; text-align: center; margin-bottom:12px; border:1px solid #fca5a5;">
      <i class="fa-solid fa-triangle-exclamation"></i>
      Add {{ spin_min_order_paise | minus: cart.total_price | money }} more to claim your Free Gift!
    </div>
  {% endif %}

  <button
    type="submit"
    id="checkout"
    class="cart__checkout-button button"
    name="checkout"
    {% if cart == empty or lock_checkout %}
      disabled
      {% if lock_checkout %}style="cursor:not-allowed; opacity:0.5;"{% endif %}
    {% endif %}
    form="cart-form"
  >
    <span class="button-text">
      {% if lock_checkout %}LOCKED{% else %}Pay Full (Prepaid){% endif %}
    </span>
  </button>

  {% unless lock_checkout %}
    {% assign advance_amount = true_total | times: 10 | divided_by: 100 %}
    {% assign cod_amount = true_total | minus: advance_amount %}
    
    <style>
      .advance-tooltip-container {
        position: relative;
        display: inline-flex;
        align-items: center;
      }
      .advance-tooltip-icon {
        background: var(--color-foreground, #0f172a);
        color: var(--color-background, #fff);
        width: 18px;
        height: 18px;
        border-radius: 50%;
        font-size: 11px;
        font-weight: bold;
        font-family: sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-left: 8px;
        cursor: help;
        transition: transform 0.2s;
      }
      .advance-tooltip-container:hover .advance-tooltip-icon {
        transform: scale(1.1);
      }
      .advance-tooltip-content {
        position: absolute;
        bottom: 140%;
        left: 50%;
        transform: translateX(-50%) translateY(10px);
        background: rgba(15, 23, 42, 0.95);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        color: #f8fafc;
        padding: 12px 16px;
        border-radius: 8px;
        width: max-content;
        min-width: 220px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.25);
        opacity: 0;
        visibility: hidden;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        z-index: 100;
        pointer-events: none;
        border: 1px solid rgba(255,255,255,0.08);
        text-align: left;
      }
      .advance-tooltip-content::after {
        content: '';
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        border-width: 6px;
        border-style: solid;
        border-color: rgba(15, 23, 42, 0.95) transparent transparent transparent;
      }
      .advance-tooltip-container:hover .advance-tooltip-content {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
      }
      .advance-tooltip-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        line-height: 1.6;
        letter-spacing: 0.3px;
      }
      .advance-tooltip-row span:first-child {
        color: #94a3b8;
        margin-right: 15px;
      }
      .advance-tooltip-row span:last-child {
        font-weight: 700;
        color: #fff;
      }
      .advance-tooltip-divider {
        height: 1px;
        background: rgba(255,255,255,0.1);
        margin: 8px 0;
      }
    </style>
    
    <button
      type="button"
      id="checkout-advance"
      class="cart__checkout-button button button--secondary"
      {% if cart == empty %}disabled{% endif %}
    >
      <span class="button-text" style="display: flex; align-items: center; justify-content: center; width: 100%;">
        Pay 10% Advance (Rest COD)
        <div class="advance-tooltip-container">
          <span class="advance-tooltip-icon">i</span>
          <div class="advance-tooltip-content">
            <div class="advance-tooltip-row">
              <span>Pay Now (10%):</span>
              <span>{{ advance_amount | money }}</span>
            </div>
            <div class="advance-tooltip-divider"></div>
            <div class="advance-tooltip-row">
              <span>Pay on Delivery:</span>
              <span>{{ cod_amount | money }}</span>
            </div>
          </div>
        </div>
      </span>
    </button>
  {% endunless %}

  {% unless lock_checkout %}
    {% if additional_checkout_buttons and settings.show_accelerated_checkout_buttons %}
      <div
        class="
          additional-checkout-buttons
          {% if accelerated_checkout_buttons_layout == 'vertical' %}additional-checkout-buttons--vertical{% endif %}
        "
      >
        {{ content_for_additional_checkout_buttons }}
      </div>
    {% endif %}
  {% endunless %}
</div>

{% render 'whatsapp-otp-modal' %}

<script>
  window.triggerAdvanceCheckout = async function(verifiedPhone) {
    const advanceBtn = document.getElementById('checkout-advance');
    if (!advanceBtn) return;
    const originalText = advanceBtn.innerHTML;
    advanceBtn.innerHTML = '<span class="button-text" style="display: flex; align-items: center; justify-content: center; gap: 8px;"><svg class="spinner" viewBox="0 0 50 50" style="width: 20px; height: 20px; animation: rotate 2s linear infinite;"><circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" style="stroke-dasharray: 1, 200; stroke-dashoffset: 0; animation: dash 1.5s ease-in-out infinite; stroke-linecap: round;"></circle></svg> Processing...</span>';
    advanceBtn.disabled = true;

    // Inject styles for spinner if they don't exist
    if (!document.getElementById('espon-spinner-style')) {
      const style = document.createElement('style');
      style.id = 'espon-spinner-style';
      style.innerHTML = `@keyframes rotate { 100% { transform: rotate(360deg); } } @keyframes dash { 0% { stroke-dasharray: 1, 200; stroke-dashoffset: 0; } 50% { stroke-dasharray: 90, 200; stroke-dashoffset: -35px; } 100% { stroke-dasharray: 90, 200; stroke-dashoffset: -124px; } }`;
      document.head.appendChild(style);
    }

    try {
      const cartRes = await fetch('/cart.js');
      const cartData = await cartRes.json();

      // Inject phone for the backend payload if newly verified
      if (verifiedPhone) {
        cartData.customer_phone = verifiedPhone;
        cartData.customer_id = '{{ customer.id }}';
      }

      const editorApiUrl = 'https://esponsports-editor.vercel.app/api/create-advance-draft';
      
      const response = await fetch(editorApiUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-client-store-url': window.location.hostname
        },
        body: JSON.stringify(cartData)
      });

      const data = await response.json();
      
      if (data.invoice_url) {
        window.location.href = data.invoice_url;
      } else {
        alert('Failed to generate advance checkout: ' + (data.error || 'Unknown error'));
        advanceBtn.innerHTML = originalText;
        advanceBtn.disabled = false;
      }
    } catch (err) {
      console.error(err);
      alert('An error occurred while creating the advance checkout.');
      advanceBtn.innerHTML = originalText;
      advanceBtn.disabled = false;
    }
  };

  window.triggerFullCheckout = function(verifiedPhone) {
    // If they just verified, the phone is already permanently attached to their 
    // Shopify profile by our backend. Submitting the cart naturally will now pull it!
    const cartForm = document.getElementById('cart-form') || document.querySelector('form[action="/cart"]');
    if (cartForm) {
      cartForm.submit();
    } else {
      window.location.href = '/checkout';
    }
  };

  document.addEventListener('DOMContentLoaded', function() {
    const advanceBtn = document.getElementById('checkout-advance');
    const fullBtn = document.getElementById('checkout');

    const isCustomerLoggedIn = {% if customer %}true{% else %}false{% endif %};
    const customerPhone = '{{ customer.phone | escape }}';
    const customerDefaultAddressPhone = '{{ customer.default_address.phone | escape }}';

    // Sometimes phone is only stored in default address
    const hasPhone = (customerPhone && customerPhone !== '') || (customerDefaultAddressPhone && customerDefaultAddressPhone !== '');

    function handleCheckoutClick(e, type) {
      e.preventDefault();
      
      /* 
      // TEMPORARILY DISABLED WHATSAPP AUTHENTICATION (Keep saved)
      if (!hasPhone) {
        // Trigger WhatsApp OTP Modal!
        if (typeof openWaModal === 'function') {
           openWaModal(type);
        } else {
           console.error("WhatsApp Modal snippet missing!");
           // Fallback to normal checkout if modal fails to load
           type === 'advance' ? window.triggerAdvanceCheckout() : window.triggerFullCheckout();
        }
      } else {
      */
        // Bypass WhatsApp auth for now
        if (type === 'advance') {
          window.triggerAdvanceCheckout();
        } else {
          window.triggerFullCheckout();
        }
      /*
      }
      */
    }

    if (advanceBtn) {
      advanceBtn.addEventListener('click', function(e) { handleCheckoutClick(e, 'advance'); });
    }
    
    if (fullBtn) {
      fullBtn.addEventListener('click', function(e) { handleCheckoutClick(e, 'full'); });
    }

    // Check if we just returned from a login redirect
    const urlParams = new URLSearchParams(window.location.search);
    const triggerCheckout = urlParams.get('trigger_checkout');
    if (triggerCheckout) {
      // Clean up the URL so it doesn't trigger again on refresh
      window.history.replaceState({}, document.title, window.location.pathname);
      
      // Auto-trigger the button they clicked before logging in
      setTimeout(() => {
        if (triggerCheckout === 'advance' && advanceBtn) {
          handleCheckoutClick({ preventDefault: () => {} }, 'advance');
        } else if (triggerCheckout === 'full' && fullBtn) {
          handleCheckoutClick({ preventDefault: () => {} }, 'full');
        }
      }, 500); // Small delay to ensure modal and everything is ready
    }
  });
</script>

{% stylesheet %}
  .cart-actions {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-block: 1px solid var(--color-border);
    padding-block: 0;
    margin-block-start: var(--margin-3xs);
  }

  .cart-actions__divider {
    border-block-start: 1px solid var(--color-border);
  }

  .cart-totals:not(:has(.cart-actions)) {
    margin-block-start: var(--margin-3xs);
    border-block-start: 1px solid var(--color-border);
    padding-block-start: var(--margin-xl);
  }

  .cart-totals__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-totals__tax-note {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .cart-totals__tax-note small {
    font-size: var(--font-size--2xs);
  }

  .cart-discounts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cart-discounts__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-discounts__label {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
  }

  .cart-discounts__label svg {
    width: var(--icon-size-sm);
    height: var(--icon-size-sm);
    display: inline-block;
  }

  .cart-totals__original-container,
  .cart-totals__container {
    display: flex;
    flex-direction: column;
  }

  .cart-totals__container {
    row-gap: var(--gap-2xs);

    &.cart-totals__container--has-installments {
      row-gap: var(--gap-xs);
    }
  }

  .cart-totals__original-container:empty {
    display: none;
  }

  .cart-totals {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xl);
    width: 100%;
    border-block-start: none;

    &:has(> :first-child:not(.cart-totals__original-container, .cart-totals__container)) {
      padding-block-start: 0;
      border-block-start: none;
    }

    @media screen and (min-width: 750px) {
      padding-block-start: 0;
    }
  }

  .cart-totals__original-container,
  .cart-totals__original-container * {
    font-size: var(--cart-font-size--sm);
  }

  .cart-totals__total {
    align-items: baseline;
    font-weight: var(--font-weight-bold);
  }

  .cart-totals__total-label {
    font-size: var(--cart-font-size--sm);
  }

  .cart-totals__total-value {
    font-size: var(--cart-font-size--xl);

    @media screen and (max-width: 749px) {
      font-size: var(--font-size--lg);
    }
  }

  .cart-totals__installments {
    color: var(--color-foreground);
    font-size: var(--font-size--2xs);
  }

  .cart-note {
    width: 100%;
  }

  @starting-style {
    .cart-note[open-by-default-on-desktop][open-by-default-on-mobile] .details-content {
      block-size: auto;
      opacity: 1;
      overflow-y: visible;
    }
  }

  .cart-note__inner {
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  .cart-note__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-note__summary:hover {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .cart-note__label {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-2xs);
    font-size: var(--font-size--2xs);
    font-weight: 500;
  }

  .cart-note__instructions {
    color: var(--color-input-text);
    background-color: var(--color-input-background);
    border-width: var(--style-border-width-inputs);
    border-color: var(--color-input-border);
    transition: box-shadow var(--animation-speed) ease;
    box-shadow: var(--input-box-shadow);
    min-height: 5.5rem;
    min-width: 100%;
    max-width: 100%;
    font-size: var(--font-size--sm);
    padding: max(4px, calc(var(--style-border-radius-inputs) * (1 - cos(45deg))));
  }

  .cart-totals__icon {
    height: var(--icon-size-xs);
    width: var(--icon-size-xs);
    margin: 0;
  }

  .cart__ctas {
    width: 100%;
    display: grid;
    gap: var(--checkout-button-gap);
    grid-auto-flow: row;
    grid-template-columns: 1fr;
  }

  .cart__ctas .cart__checkout-button {
    width: 100%;
    height: clamp(25px, var(--height-buy-buttons), 55px);
    padding-inline: var(--padding-4xl);
  }

  .cart-drawer__summary .cart-totals:not(:has(.cart-totals__original-container:empty)) {
    border-block-start: var(--style-border-width) solid var(--color-border);
    padding-block-start: var(--padding-2xl);
  }

  .cart-drawer__summary .cart-note {
    @media screen and (min-width: 750px) {
      margin-block-start: var(--margin-3xs);
    }
  }

  .cart-discount__input {
    background-color: var(--color-input-background);
    color: var(--color-input-text);
    border-width: var(--style-border-width-inputs);
    border-color: var(--color-input-border);
    border-style: solid;
    border-radius: var(--style-border-radius-inputs);
    padding: var(--padding-sm) var(--padding-md);
    height: 100%;
    flex-grow: 1;
    min-width: 0;
    font-size: var(--font-size--sm);
  }

  .cart-discount__input::placeholder {
    color: rgb(var(--color-input-text-rgb) / var(--opacity-subdued-text));
  }

  .cart-discount__pill-code {
    overflow: hidden;
    max-width: 100px;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin: 0;
  }

  .cart-discount {
    width: 100%;
  }

  .cart-discount__codes {
    display: none;
    gap: var(--padding-xs);
    flex-wrap: wrap;
    list-style: none;
    padding-inline: 0;
    margin: 0;
  }

  .cart-discount__codes:has(.cart-discount__pill) {
    display: flex;
  }

  .cart-discount__button {
    height: 100%;
  }

  .cart-discount__content {
    height: calc(var(--button-size) + var(--padding-2xs) + var(--padding-sm));
  }

  .cart-discount__pill {
    display: flex;
    color: var(--color-foreground);
    gap: var(--padding-xs);
    align-items: center;
    padding: var(--padding-xs) var(--padding-sm);
    border-radius: var(--style-border-radius-pills);
    background-color: var(--color-input-background);
    text-transform: uppercase;
  }

  .cart-discount__form {
    display: flex;
    gap: var(--padding-md);
    align-items: center;
    height: 100%;
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  :is(.cart-discount__pill-remove, .cart-discount__pill-remove:hover) {
    --close-icon-opacity: 0.4;

    color: var(--color-foreground);
    background-color: transparent;
    pointer-events: all;
    cursor: pointer;
    height: 100%;
  }

  .cart-discount__error {
    display: flex;
    align-items: center;
    width: 100%;
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  .cart-discount__error .svg-wrapper {
    flex-shrink: 0;
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
    margin-inline: var(--margin-3xs) var(--margin-xs);
  }

  .cart-discount__error-text {
    margin-block-start: var(--margin-3xs);
  }

  .cart-discount__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-discount__summary:hover {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .cart-discount__label {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-2xs);
    font-size: var(--font-size--2xs);
    font-weight: 500;
  }

  @media screen and (min-width: 750px) {
    .cart-summary--extend {
      height: 100%;
    }
  }
{% endstylesheet %}
