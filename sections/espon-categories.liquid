<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  #shopify-section-{{ section.id }} {
    --navy: {{ section.settings.heading_color }};
    --border: {{ section.settings.border_color }};
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  /* --- ANIMATION --- */
  #shopify-section-{{ section.id }} .reveal-up {
    opacity: 0;
    transform: translateY(50px) translateZ(-50px) rotateX(-5deg);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #shopify-section-{{ section.id }} .reveal-up.active {
    opacity: 1;
    transform: translateY(0) translateZ(0) rotateX(0deg);
  }

  /* --- CATEGORIES SECTION --- */
  #shopify-section-{{ section.id }} .cat-header-wrapper {
    text-align: center; 
    margin: {{ section.settings.padding_top }}px 0 40px;
  }
  
  #shopify-section-{{ section.id }} .cat-header-wrapper h2 {
    font-size: 3.5rem; 
    font-weight: 900; 
    margin: 0; 
    color: var(--navy); 
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .collection-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 15px;
    padding: 0 5% {{ section.settings.padding_bottom }}px;
    align-items: start; 
  }

  #shopify-section-{{ section.id }} .collection-grid .glass-card {
    padding: 0;
    overflow: hidden;
    height: auto !important;
    border: 1px solid var(--border);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    position: relative; 
    text-decoration: none;
  }

  /* Fixed Aspect Ratio 4:5 */
  #shopify-section-{{ section.id }} .cat-img-wrapper {
    width: 100%;
    padding-bottom: 125%; /* 5/4 * 100 = 125% */
    position: relative;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .collection-grid .glass-card img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-color: #fff;
    display: block;
    transition: 0.5s;
  }
  
  #shopify-section-{{ section.id }} .glass-card:hover img { 
    transform: scale(1.05); 
  }

  #shopify-section-{{ section.id }} .cat-overlay {
    position: absolute; 
    bottom: 0; 
    left: 0; 
    width: 100%; 
    padding: 30px; 
    background: linear-gradient(to top, #0f172a, transparent);
  }

  #shopify-section-{{ section.id }} .cat-overlay h3 {
    font-size: 2.2rem; 
    font-weight: 900; 
    margin: 0; 
    color: white;
  }

  #shopify-section-{{ section.id }} .cat-overlay span {
    font-weight: 800; 
    font-size: 1.1rem;
  }

  /* --- MOBILE OPTIMIZATION --- */
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .cat-header-wrapper {
      margin: {{ section.settings.padding_top_mobile }}px 0 25px !important;
    }
    
    #shopify-section-{{ section.id }} .collection-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 10px;
      padding-left: 10px; 
      padding-right: 10px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }

    #shopify-section-{{ section.id }} .collection-grid .glass-card {
      padding: 0; 
    }

    #shopify-section-{{ section.id }} .cat-overlay {
      padding: 15px; 
    }

    #shopify-section-{{ section.id }} .cat-overlay h3 {
      font-size: 1.2rem !important;
      margin-bottom: 5px;
    }

    #shopify-section-{{ section.id }} .cat-overlay span {
      font-size: 0.85rem !important;
      line-height: 1.2;
    }
  }
</style>

<div class="cat-header-wrapper reveal-up" id="cat-header-{{ section.id }}">
  <h2>{{ section.settings.heading_text }}</h2>
</div>

<section class="collection-grid" id="cat-grid-{{ section.id }}">
  {%- if section.blocks.size > 0 -%}
    {%- for block in section.blocks -%}
      {%- assign collection = block.settings.collection -%}
      {%- if collection != blank -%}
        {%- assign delay = forloop.index0 | times: 0.2 -%}
        <a href="{{ collection.url }}" class="glass-card reveal-up" style="transition-delay: {{ delay }}s;" {{ block.shopify_attributes }}>
          <div class="cat-img-wrapper">
            {%- assign col_image = collection.image | default: collection.products.first.featured_image -%}
            {% if col_image != blank %}
              <img src="{{ col_image | img_url: '800x1000', crop: 'center' }}" alt="{{ collection.title | escape }}" loading="lazy">
            {% else %}
              <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #f1f5f9; display: flex; align-items: center; justify-content: center; color: #94a3b8;">No Image</div>
            {% endif %}
          </div>
          <div class="cat-overlay">
            <h3>{{ collection.title }}</h3>
            <span style="color: {{ section.settings.subtitle_color }};">Explore &rarr;</span>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  {%- else -%}
    <!-- Fallback or Placeholder -->
    {%- for i in (1..4) -%}
      <div class="glass-card reveal-up">
        <div class="cat-img-wrapper">
          <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #f1f5f9; display: flex; align-items: center; justify-content: center; color: #94a3b8;">Select Collection</div>
        </div>
        <div class="cat-overlay">
          <h3>Collection {{ i }}</h3>
          <span style="color: {{ section.settings.subtitle_color }};">Explore &rarr;</span>
        </div>
      </div>
    {%- endfor -%}
  {%- endif -%}
</section>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.2 });
    
    const elements = document.querySelectorAll('#shopify-section-{{ section.id }} .reveal-up');
    elements.forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Espon Categories",
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading",
      "default": "EXPLORE CATEGORIES"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card Border Color",
      "default": "#e2e8f0"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#CA8A04"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top Margin",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 50
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Margin (Mobile)",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Espon Categories Dynamic"
    }
  ]
}
{% endschema %}