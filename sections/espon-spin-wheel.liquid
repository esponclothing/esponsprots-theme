{% comment %} espon-spin-wheel.liquid — Save in sections/ folder {% endcomment %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
/* ============================================================
   ESPON SPIN WHEEL — REDESIGNED
   ============================================================ */

.eiws-section {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background: radial-gradient(circle at 30% 50%, #FEFCE8 0%, #ffffff 70%);
  padding: 80px 5%;
  position: relative;
  overflow: hidden;
  --eiws-bg:          #ffffff;
  --eiws-card-bg:     #ffffff;
  --eiws-card-bg2:    #FFFBEB;
  --eiws-border:      #e2e8f0;
  --eiws-text:        #0f172a;
  --eiws-subtext:     #64748b;
  --eiws-muted:       #94a3b8;
  --eiws-wheel-a:     #f1f5f9;
  --eiws-wheel-b:     #e2e8f0;
  --eiws-wheel-border:#e2e8f0;
  --eiws-slice-highlight: rgba(202,138,4,0.15);
}

.eiws-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(202,138,4,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(202,138,4,0.04) 1px, transparent 1px);
  background-size: 50px 50px;
  pointer-events: none;
}
.eiws-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
  opacity: 0.08;
}
.eiws-orb-1 {
  width: 400px; height: 400px;
  background: #CA8A04;
  top: -100px; right: -100px;
}
.eiws-orb-2 {
  width: 300px; height: 300px;
  background: #CA8A04;
  bottom: -80px; left: -80px;
}

/* ---- SECTION HEADER ---- */
.eiws-header {
  text-align: center;
  margin-bottom: 50px;
  position: relative;
  z-index: 2;
}
.eiws-header-badge {
  display: inline-block;
  background: #FFFBEB;
  border: 1px solid #CA8A04;
  color: #CA8A04;
  padding: 6px 20px;
  border-radius: 50px;
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 16px;
}
.eiws-header h2 {
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 900;
  color: #0f172a;
  margin: 0 0 12px;
  line-height: 1.1;
}
.eiws-header h2 span { color: #CA8A04; }
.eiws-header p {
  color: #64748b;
  font-size: 1rem;
  max-width: 500px;
  margin: 0 auto;
}

/* ---- MAIN LAYOUT ---- */
.eiws-layout {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 40px;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
}

/* ---- LEFT PANEL — iPhone Jackpot ---- */
.eiws-jackpot-panel {
  background: linear-gradient(135deg, #FFFBEB 0%, #ffffff 100%);
  border: 1px solid rgba(202,138,4,0.3);
  border-radius: 24px;
  padding: 35px 30px;
  text-align: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(202,138,4,0.08);
  /* Added Flexbox to strictly center everything top-to-bottom */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.eiws-jackpot-panel::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(202,138,4,0.08) 0%, transparent 60%);
  pointer-events: none;
}
/* Shimmering border animation */
.eiws-jackpot-panel::after {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: 26px;
  background: linear-gradient(90deg, #CA8A04, transparent, #CA8A04, transparent);
  background-size: 300% 100%;
  animation: borderShimmer 3s linear infinite;
  z-index: -1;
  opacity: 0.6;
}
@keyframes borderShimmer {
  0%   { background-position: 0% 50%; }
  100% { background-position: 300% 50%; }
}

.eiws-jackpot-crown {
  font-size: 2.5rem;
  animation: crownBounce 2s ease-in-out infinite;
  display: block;
  margin-bottom: 10px;
}
@keyframes crownBounce {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  50%       { transform: translateY(-8px) rotate(5deg); }
}

.eiws-jackpot-img-wrap {
  position: relative;
  display: flex; /* Changed to flex to ensure centering */
  justify-content: center;
  margin: 10px auto;
  width: 100%;
}
.eiws-jackpot-img-wrap img {
  width: 130px;
  height: auto;
  filter: drop-shadow(0 0 30px rgba(202,138,4,0.5));
  animation: phoneFloat 4s ease-in-out infinite;
  position: relative;
  z-index: 2;
}
@keyframes phoneFloat {
  0%, 100% { transform: translateY(0) rotateY(0deg); }
  25%       { transform: translateY(-12px) rotateY(5deg); }
  75%       { transform: translateY(-6px) rotateY(-5deg); }
}
/* Glow ring under phone */
.eiws-phone-glow {
  position: absolute;
  bottom: -10px; left: 50%;
  transform: translateX(-50%);
  width: 100px; height: 30px;
  background: radial-gradient(ellipse, rgba(202,138,4,0.5) 0%, transparent 70%);
  animation: glowPulse 2s ease-in-out infinite;
}
@keyframes glowPulse {
  0%, 100% { opacity: 0.5; transform: translateX(-50%) scaleX(1); }
  50%       { opacity: 1;   transform: translateX(-50%) scaleX(1.3); }
}

.eiws-jackpot-label {
  display: inline-block;
  background: linear-gradient(135deg, #CA8A04, #fbbf24);
  color: #0a0f1e;
  font-weight: 900;
  font-size: 0.7rem;
  letter-spacing: 2px;
  padding: 5px 14px;
  border-radius: 50px;
  text-transform: uppercase;
  margin: 6px 0;
}
.eiws-jackpot-name {
  font-size: 1.3rem;
  font-weight: 900;
  color: #0f172a;
  margin: 8px 0 4px;
  line-height: 1.2;
}
.eiws-jackpot-sub {
  font-size: 0.8rem;
  color: #94a3b8;
  margin-bottom: 16px;
}

/* Odds badge */
.eiws-odds {
  background: rgba(220,38,38,0.15);
  border: 1px solid rgba(220,38,38,0.3);
  color: #f87171;
  font-size: 0.72rem;
  font-weight: 700;
  padding: 6px 14px;
  border-radius: 8px;
  display: inline-block;
  margin-bottom: 10px;
}
.eiws-odds i { margin-right: 5px; }

/* Stars */
.eiws-jackpot-stars {
  color: #CA8A04;
  font-size: 0.85rem;
  margin-bottom: 6px;
  letter-spacing: 3px;
}

/* ---- CENTER WHEEL ---- */
.eiws-wheel-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

/* Outer ring decoration */
.eiws-wheel-ring {
  position: relative;
  width: 360px;
  height: 360px;
  flex-shrink: 0;
}
/* Spinning outer ring */
.eiws-wheel-ring::before {
  content: '';
  position: absolute;
  inset: -8px;
  border-radius: 50%;
  background: conic-gradient(
    #CA8A04 0deg 60deg, transparent 60deg 120deg,
    #CA8A04 120deg 180deg, transparent 180deg 240deg,
    #CA8A04 240deg 300deg, transparent 300deg 360deg
  );
  animation: ringRotate 8s linear infinite;
  opacity: 0.6;
}
@keyframes ringRotate {
  to { transform: rotate(360deg); }
}
/* Outer glow ring */
.eiws-wheel-ring::after {
  content: '';
  position: absolute;
  inset: -16px;
  border-radius: 50%;
  border: 2px solid rgba(202,138,4,0.2);
  box-shadow: 0 0 40px rgba(202,138,4,0.15), inset 0 0 40px rgba(202,138,4,0.05);
}

/* Pointer */
.eiws-pointer-wrap {
  position: absolute;
  top: -28px; left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  filter: drop-shadow(0 4px 8px rgba(0,0,0,0.6));
}
.eiws-pointer-svg {
  width: 36px;
  animation: pointerWiggle 0.1s ease-in-out;
}
@keyframes pointerWiggle {
  0%, 100% { transform: rotate(0deg); }
  25%       { transform: rotate(-8deg); }
  75%       { transform: rotate(8deg); }
}

/* The actual wheel canvas */
.eiws-wheel {
  width: 360px;
  height: 360px;
  border-radius: 50%;
  border: 8px solid var(--eiws-wheel-border);
  box-shadow:
    0 0 0 3px rgba(202,138,4,0.3),
    0 20px 60px rgba(0,0,0,0.6),
    inset 0 0 30px rgba(0,0,0,0.3);
  position: relative;
  overflow: hidden;
  cursor: pointer;
}

.eiws-slice-container {
  position: absolute;
  inset: 0;
  border-radius: 50%;
}

/* Each spoke */
.eiws-spoke {
  position: absolute;
  top: 0; left: 50%;
  width: 110px;
  height: 50%;
  margin-left: -55px;
  transform-origin: bottom center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 18px;
  overflow: hidden;
}
.eiws-spoke img {
  width: 36px; height: 36px;
  object-fit: contain;
  margin-bottom: 5px;
  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  z-index: 2;
  position: relative;
}
.eiws-spoke span {
  font-size: 8px;
  font-weight: 900;
  color: #1e293b;
  text-align: center;
  line-height: 1.2;
  text-transform: uppercase;
  width: 90%;
  word-wrap: break-word;
  position: relative;
  z-index: 2;
}

/* Dividers between slices */
.eiws-divider {
  position: absolute;
  top: 0; left: 50%;
  width: 2px;
  height: 50%;
  margin-left: -1px;
  transform-origin: bottom center;
  background: linear-gradient(to top, rgba(30,41,59,0.8) 0%, rgba(30,41,59,0) 100%);
  z-index: 4;
}

/* Alternating slice backgrounds */
.eiws-slice-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: conic-gradient(
    var(--eiws-wheel-a) 0deg 60deg,
    var(--eiws-wheel-b) 60deg 120deg,
    var(--eiws-wheel-a) 120deg 180deg,
    var(--eiws-wheel-b) 180deg 240deg,
    var(--eiws-wheel-a) 240deg 300deg,
    var(--eiws-wheel-b) 300deg 360deg
  );
}

/* iPhone Jackpot spoke — special */
.eiws-spoke.mega-spoke img {
  width: 44px; height: 44px;
  filter:
    drop-shadow(0 0 8px rgba(202,138,4,0.9))
    drop-shadow(0 0 20px rgba(202,138,4,0.5));
  animation: megaGlow 1.5s infinite alternate;
}
.eiws-spoke.mega-spoke span { color: #CA8A04; font-size: 9px; }
@keyframes megaGlow {
  0%   { filter: drop-shadow(0 0 6px rgba(202,138,4,0.8)) drop-shadow(0 0 15px rgba(202,138,4,0.4)); transform: scale(1); }
  100% { filter: drop-shadow(0 0 12px rgba(202,138,4,1))  drop-shadow(0 0 30px rgba(202,138,4,0.7)); transform: scale(1.12); }
}
/* Gold slice highlight for iPhone */
.eiws-slice-bg-mega {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: conic-gradient(
    var(--eiws-slice-highlight) 0deg 60deg,
    transparent 60deg 360deg
  );
  pointer-events: none;
  z-index: 1;
}

/* Jackpot badge on wheel */
.eiws-jackpot-wheel-badge {
  position: absolute;
  background: linear-gradient(135deg, #CA8A04, #fbbf24);
  color: #0a0f1e;
  font-size: 7px;
  font-weight: 900;
  padding: 3px 8px;
  border-radius: 4px;
  margin-top: 3px;
  letter-spacing: 0.5px;
  z-index: 2;
  position: relative;
}

/* Center button */
.eiws-center-btn {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 88px; height: 88px;
  border-radius: 50%;
  border: 5px solid #0a0f1e;
  box-shadow:
    0 0 0 2px rgba(202,138,4,0.5),
    0 0 30px rgba(0,0,0,0.8),
    inset 0 2px 4px rgba(255,255,255,0.1);
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  background: linear-gradient(135deg, #CA8A04 0%, #fbbf24 50%, #CA8A04 100%);
  color: #0a0f1e;
  text-transform: uppercase;
  text-align: center;
  line-height: 1;
  font-family: inherit;
}
.eiws-center-btn:hover:not(.disabled) {
  transform: translate(-50%, -50%) scale(1.12);
  box-shadow: 0 0 0 2px #CA8A04, 0 0 40px rgba(202,138,4,0.6), inset 0 2px 4px rgba(255,255,255,0.2);
}
.eiws-center-btn i   { font-size: 1.6rem; margin-bottom: 2px; display: block; }
.eiws-center-btn span { font-size: 9px; font-weight: 900; letter-spacing: 0.5px; display: block; }
.eiws-center-btn.disabled {
  background: #334155;
  color: #64748b;
  cursor: not-allowed;
  box-shadow: 0 0 0 2px rgba(100,116,139,0.3), 0 0 20px rgba(0,0,0,0.4);
}

/* ---- RIGHT PANEL — Prizes + Login ---- */
.eiws-prizes-panel {
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 24px;
  padding: 30px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.04);
}

.eiws-panel-title {
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 2px;
  color: #0f172a;
  text-transform: uppercase;
  margin-bottom: 4px;
}

/* Dropdown Toggle Fix */
.eiws-prizes-toggle-btn {
  background: rgba(202,138,4,0.08);
  border: 1px solid rgba(202,138,4,0.3);
  color: #0f172a;
  padding: 10px 15px;
  border-radius: 12px;
  font-weight: 700;
  font-size: 0.85rem;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  transition: all 0.3s;
}
.eiws-prizes-toggle-btn:hover {
  background: rgba(202,138,4,0.15);
}
.eiws-prizes-toggle-btn i {
  transition: transform 0.3s;
}
.eiws-prizes-toggle-btn.active i {
  transform: rotate(180deg);
}

.eiws-prizes-list {
  display: none; /* Hidden by default */
  flex-direction: column;
  gap: 12px;
  margin-top: 5px;
}
.eiws-prizes-list.show {
  display: flex; /* Shown when toggled */
}

.eiws-prize-row {
  display: flex;
  align-items: center;
  gap: 12px;
  background: rgba(128,128,128,0.05);
  border: 1px solid var(--eiws-border);
  border-radius: 12px;
  padding: 10px 14px;
  transition: 0.2s;
}
.eiws-prize-row:hover {
  background: rgba(202,138,4,0.07);
  border-color: rgba(202,138,4,0.2);
}
.eiws-prize-img {
  width: 40px; height: 40px;
  object-fit: contain;
  border-radius: 8px;
  background: rgba(255,255,255,0.05);
  padding: 4px;
  flex-shrink: 0;
}
.eiws-prize-info { flex: 1; min-width: 0; }
.eiws-prize-name {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--eiws-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.eiws-prize-chip {
  display: inline-block;
  background: rgba(34,197,94,0.15);
  border: 1px solid rgba(34,197,94,0.3);
  color: #4ade80;
  font-size: 0.6rem;
  font-weight: 800;
  padding: 2px 8px;
  border-radius: 50px;
  margin-top: 2px;
  letter-spacing: 0.5px;
}

/* CTA / Login box */
.eiws-cta-box {
  background: linear-gradient(135deg, rgba(202,138,4,0.12) 0%, rgba(202,138,4,0.04) 100%);
  border: 1px solid rgba(202,138,4,0.25);
  border-radius: 14px;
  padding: 18px;
  text-align: center;
  margin-top: 4px;
}
.eiws-cta-box p {
  color: #94a3b8;
  font-size: 0.82rem;
  margin: 0 0 12px;
  line-height: 1.5;
}
.eiws-cta-box strong { color: #e2e8f0; }
.eiws-cta-btn {
  display: block;
  background: linear-gradient(135deg, #CA8A04, #fbbf24);
  color: #0a0f1e;
  font-weight: 900;
  font-size: 0.85rem;
  padding: 12px 20px;
  border-radius: 10px;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 1px;
  transition: 0.3s;
  box-shadow: 0 8px 20px rgba(202,138,4,0.3);
}
.eiws-cta-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 30px rgba(202,138,4,0.4);
}
.eiws-register-link {
  display: block;
  margin-top: 10px;
  font-size: 0.78rem;
  color: #64748b;
}
.eiws-register-link a {
  color: #CA8A04;
  font-weight: 700;
  text-decoration: none;
}

/* ---- WIN STATE ---- */
.eiws-win-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.85);
  z-index: 9999;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(8px);
}
.eiws-win-overlay.show { display: flex; }
.eiws-win-card {
  background: linear-gradient(135deg, #ffffff 0%, #FFFBEB 100%);
  border: 2px solid #CA8A04;
  border-radius: 30px;
  padding: 50px 40px;
  text-align: center;
  max-width: 440px;
  width: 90%;
  position: relative;
  animation: winPop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 0 0 80px rgba(202,138,4,0.3);
}
@keyframes winPop {
  from { transform: scale(0.5) rotate(-5deg); opacity: 0; }
  to   { transform: scale(1) rotate(0deg);   opacity: 1; }
}
/* Confetti burst on win */
.eiws-win-emoji { font-size: 4rem; display: block; margin-bottom: 10px; animation: emojiBounce 0.5s 0.3s both; }
@keyframes emojiBounce {
  from { transform: scale(0); }
  to   { transform: scale(1); }
}
.eiws-win-card h3 { font-size: 2rem; color: #0f172a; font-weight: 900; margin: 0 0 8px; }
.eiws-win-card h3 span { color: #CA8A04; }
.eiws-win-prize-name {
  font-size: 1.5rem;
  font-weight: 900;
  color: #CA8A04;
  background: rgba(202,138,4,0.12);
  border: 2px dashed rgba(202,138,4,0.4);
  border-radius: 14px;
  padding: 16px 24px;
  margin: 16px 0;
  display: block;
}
.eiws-win-card p { color: #475569; font-size: 0.9rem; margin: 0 0 20px; line-height: 1.6; }
.eiws-win-cart-btn {
  display: block;
  background: linear-gradient(135deg, #CA8A04, #fbbf24);
  color: #0a0f1e;
  font-weight: 900;
  font-size: 1rem;
  padding: 16px 30px;
  border-radius: 14px;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 12px;
  transition: 0.3s;
}
.eiws-win-cart-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(202,138,4,0.4); }
.eiws-win-close {
  background: none;
  border: none;
  color: #475569;
  font-size: 0.85rem;
  cursor: pointer;
  font-family: inherit;
  font-weight: 600;
  padding: 8px;
}
.eiws-win-close:hover { color: #94a3b8; }

/* Used-up state */
.eiws-used-banner {
  background: rgba(220,38,38,0.1);
  border: 1px dashed rgba(220,38,38,0.3);
  border-radius: 10px;
  padding: 12px 16px;
  text-align: center;
  color: #f87171;
  font-size: 0.82rem;
  font-weight: 700;
  margin-top: 4px;
}

/* ---- MOBILE RESPONSIVENESS FIXES ---- */
@media (max-width: 768px) {
  .eiws-section { padding: 40px 4%; }
  .eiws-header { margin-bottom: 30px; }
  .eiws-header h2 { font-size: 1.8rem; }
  .eiws-layout { gap: 20px; max-width: 480px; }
  .eiws-jackpot-panel { padding: 20px; }
  .eiws-jackpot-img-wrap img { width: 100px; }
  .eiws-prizes-panel { padding: 20px; }
}

@media (max-width: 1000px) {
  .eiws-layout {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto auto;
    max-width: 480px;
  }
  .eiws-jackpot-panel { order: 2; }
  .eiws-wheel-col     { order: 1; }
  .eiws-prizes-panel  { order: 3; }
  .eiws-wheel-ring,
  .eiws-wheel { width: 300px; height: 300px; }
  .eiws-pointer-wrap { top: -24px; }
}

@media (max-width: 480px) {
  .eiws-section { padding: 30px 4%; }
  .eiws-wheel-ring,
  .eiws-wheel { width: 260px; height: 260px; }
  .eiws-spoke { width: 90px; margin-left: -45px; }
  .eiws-spoke img { width: 28px; height: 28px; }
  .eiws-center-btn { width: 72px; height: 72px; }
  .eiws-center-btn i { font-size: 1.3rem; }
}

/* Particle burst */
.eiws-particle {
  position: fixed;
  width: 8px; height: 8px;
  border-radius: 50%;
  pointer-events: none;
  z-index: 10000;
  animation: particleFly 1s ease-out forwards;
}
@keyframes particleFly {
  to { opacity: 0; transform: translate(var(--tx), var(--ty)) scale(0); }
}
</style>

<!-- WIN OVERLAY -->
<div class="eiws-win-overlay" id="eiwsWinOverlay">
  <div class="eiws-win-card">
    <span class="eiws-win-emoji">🎉</span>
    <h3>YOU <span>WON!</span></h3>
    <span class="eiws-win-prize-name" id="eiwsWonText">Loading...</span>
    <p>
      Your reward has been added to your cart for just <strong>₹1</strong>.<br>
      Valid for <strong>30 minutes</strong> on orders over
      <strong>₹{{ section.settings.min_order_amount | default: 10000 }}</strong>.
    </p>
    <a href="/cart" class="eiws-win-cart-btn">
      <i class="fas fa-shopping-cart"></i> &nbsp;GO TO CART
    </a>
    <button class="eiws-win-close" onclick="document.getElementById('eiwsWinOverlay').classList.remove('show')">
      Maybe later
    </button>
  </div>
</div>

<section class="eiws-section" data-theme="light">
  <!-- Background decoration -->
  <div class="eiws-orb eiws-orb-1"></div>
  <div class="eiws-orb eiws-orb-2"></div>

  <!-- Header -->
  <div class="eiws-header">
    <div class="eiws-header-badge">🎰 Daily B2B Reward</div>
    <h2>SPIN & <span>WIN</span> TODAY</h2>
    <p>Exclusive physical rewards for our B2B partners. Every spin, a real prize added to your cart.</p>
  </div>

  <!-- 3-column layout -->
  <div class="eiws-layout">

    <!-- LEFT: iPhone Jackpot Showcase -->
    <div class="eiws-jackpot-panel">
      <span class="eiws-jackpot-crown">👑</span>
      <div class="eiws-jackpot-stars">★ ★ ★ ★ ★</div>
      
      <div class="eiws-jackpot-label">🏆 MEGA JACKPOT</div>

      <div class="eiws-jackpot-img-wrap">
        {% if section.settings.mega_image != blank %}
          <img src="{{ section.settings.mega_image | img_url: '300x' }}" alt="{{ section.settings.mega_name }}">
        {% else %}
          <div style="font-size:6rem; line-height:1;">📱</div>
        {% endif %}
        <div class="eiws-phone-glow"></div>
      </div>

      <div class="eiws-jackpot-name">{{ section.settings.mega_name | default: 'iPhone 17 Pro Max' }}</div>
      <div class="eiws-jackpot-sub">Worth ₹{{ section.settings.mega_value | default: '1,34,900' }}</div>

      <div class="eiws-odds">
        <i class="fas fa-lock"></i> Astronomically Rare
      </div>

      <div style="margin-top: 18px; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.06);">
        <div style="font-size: 0.72rem; color: #475569; line-height: 1.6;">
          The jackpot prize is real — but only the luckiest of the lucky partners ever win it. Keep spinning daily to increase your chances.
        </div>
      </div>
    </div>

    <!-- CENTER: Wheel -->
    <div class="eiws-wheel-col">

      <div class="eiws-wheel-ring" id="eiwsWheelRing">
        <!-- Pointer -->
        <div class="eiws-pointer-wrap">
          <svg class="eiws-pointer-svg" viewBox="0 0 36 44" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 44L0 8C0 3.58 8.06 0 18 0C27.94 0 36 3.58 36 8L18 44Z" fill="#CA8A04"/>
            <path d="M18 38L4 10C4 6.69 10.27 4 18 4C25.73 4 32 6.69 32 10L18 38Z" fill="#fbbf24"/>
            <circle cx="18" cy="10" r="5" fill="#0a0f1e"/>
          </svg>
        </div>

        <div class="eiws-wheel" id="eiwsWheel">
          <!-- Slice backgrounds -->
          <div class="eiws-slice-bg"></div>
          <div class="eiws-slice-bg-mega"></div>

          <!-- Dividers -->
          <div class="eiws-divider" style="transform: rotate(0deg);"></div>
          <div class="eiws-divider" style="transform: rotate(60deg);"></div>
          <div class="eiws-divider" style="transform: rotate(120deg);"></div>
          <div class="eiws-divider" style="transform: rotate(180deg);"></div>
          <div class="eiws-divider" style="transform: rotate(240deg);"></div>
          <div class="eiws-divider" style="transform: rotate(300deg);"></div>

          <div class="eiws-slice-container">

            <!-- SLOT 0 — iPhone Jackpot (30deg = top-right slice, pointer at top = 0deg offset) -->
            <div class="eiws-spoke mega-spoke" style="transform: rotate(30deg);">
              {% if section.settings.mega_image != blank %}
                <img src="{{ section.settings.mega_image | img_url: '100x' }}" alt="{{ section.settings.mega_name }}">
              {% else %}
                <span style="font-size:2rem;">📱</span>
              {% endif %}
              <span>{{ section.settings.mega_name | default: 'iPhone 17' | truncate: 10 }}</span>
              <div class="eiws-jackpot-wheel-badge">JACKPOT</div>
            </div>

            <!-- SLOT 1 -->
            <div class="eiws-spoke" style="transform: rotate(90deg);">
              {% assign p1 = section.settings.r1_product %}
              {% if p1 != blank and p1.featured_image %}
                <img src="{{ p1.featured_image | img_url: '100x' }}" alt="{{ p1.title }}">
                <span>{{ p1.title | truncate: 14 }}</span>
              {% else %}
                <span style="font-size:1.4rem;">🎁</span>
                <span>Gift 1</span>
              {% endif %}
            </div>

            <!-- SLOT 2 -->
            <div class="eiws-spoke" style="transform: rotate(150deg);">
              {% assign p2 = section.settings.r2_product %}
              {% if p2 != blank and p2.featured_image %}
                <img src="{{ p2.featured_image | img_url: '100x' }}" alt="{{ p2.title }}">
                <span>{{ p2.title | truncate: 14 }}</span>
              {% else %}
                <span style="font-size:1.4rem;">🎁</span>
                <span>Gift 2</span>
              {% endif %}
            </div>

            <!-- SLOT 3 -->
            <div class="eiws-spoke" style="transform: rotate(210deg);">
              {% assign p3 = section.settings.r3_product %}
              {% if p3 != blank and p3.featured_image %}
                <img src="{{ p3.featured_image | img_url: '100x' }}" alt="{{ p3.title }}">
                <span>{{ p3.title | truncate: 14 }}</span>
              {% else %}
                <span style="font-size:1.4rem;">🎁</span>
                <span>Gift 3</span>
              {% endif %}
            </div>

            <!-- SLOT 4 -->
            <div class="eiws-spoke" style="transform: rotate(270deg);">
              {% assign p4 = section.settings.r4_product %}
              {% if p4 != blank and p4.featured_image %}
                <img src="{{ p4.featured_image | img_url: '100x' }}" alt="{{ p4.title }}">
                <span>{{ p4.title | truncate: 14 }}</span>
              {% else %}
                <span style="font-size:1.4rem;">🎁</span>
                <span>Gift 4</span>
              {% endif %}
            </div>

            <!-- SLOT 5 -->
            <div class="eiws-spoke" style="transform: rotate(330deg);">
              {% assign p5 = section.settings.r5_product %}
              {% if p5 != blank and p5.featured_image %}
                <img src="{{ p5.featured_image | img_url: '100x' }}" alt="{{ p5.title }}">
                <span>{{ p5.title | truncate: 14 }}</span>
              {% else %}
                <span style="font-size:1.4rem;">🎁</span>
                <span>Gift 5</span>
              {% endif %}
            </div>

          </div>

          <!-- Center spin button -->
          <button class="eiws-center-btn" id="eiwsSpinCenter" onclick="eiwsStartSpin()">
            <i class="fas fa-bolt"></i>
            <span>TAP<br>TO SPIN</span>
          </button>
        </div>
      </div>

      <!-- Spin limit info -->
      <div style="text-align:center;">
        <div style="color:#475569; font-size:0.78rem; font-weight:600;">
          <i class="fas fa-sync-alt" style="color:#CA8A04; margin-right:5px;"></i>
          {{ section.settings.daily_spin_limit | default: 1 }} Free Spin(s) Per Day
        </div>
      </div>

    </div>

    <!-- RIGHT: Prizes List + Login CTA -->
    <div class="eiws-prizes-panel">
      <div class="eiws-panel-title">🎁 Today's Prizes</div>

      <!-- Dropdown Button Added -->
      <button class="eiws-prizes-toggle-btn" onclick="window.togglePrizes()">
        <span>View Available Prizes</span>
        <i class="fas fa-chevron-down"></i>
      </button>

      <!-- Prizes hidden inside wrapper by default -->
      <div class="eiws-prizes-list" id="eiwsPrizesList">
        {% assign prizes = "" %}
        {% for i in (1..5) %}
          {% assign pid = 'r' | append: i | append: '_product' %}
          {% assign p = section.settings[pid] %}
          {% if p != blank %}
          <div class="eiws-prize-row">
            {% if p.featured_image %}
              <img src="{{ p.featured_image | img_url: '80x' }}" alt="{{ p.title }}" class="eiws-prize-img">
            {% else %}
              <div class="eiws-prize-img" style="display:flex;align-items:center;justify-content:center;font-size:1.5rem;">🎁</div>
            {% endif %}
            <div class="eiws-prize-info">
              <div class="eiws-prize-name">{{ p.title }}</div>
              <span class="eiws-prize-chip">WIN FOR ₹1</span>
            </div>
          </div>
          {% endif %}
        {% endfor %}
      </div>

      <!-- CTA Box -->
      <div class="eiws-cta-box">
        <p>Welcome! 🎯<br>Spin the wheel today to unlock an exclusive physical reward for just ₹1 on orders over <strong>₹{{ section.settings.min_order_amount | default: 10000 }}</strong>.</p>
        <div id="eiwsActionDisplay"></div>
      </div>

    </div>
  </div>
</section>

<script>
(function() {

  // ---- CONFIG ----
  const WHEEL_REWARDS = [
    null, // slot 0 = iPhone — NEVER wins (null = blocked)
    { name: {{ section.settings.r1_product.title | default: 'Gift 1' | json }}, vid: "{{ section.settings.r1_product.variants.first.id }}" },
    { name: {{ section.settings.r2_product.title | default: 'Gift 2' | json }}, vid: "{{ section.settings.r2_product.variants.first.id }}" },
    { name: {{ section.settings.r3_product.title | default: 'Gift 3' | json }}, vid: "{{ section.settings.r3_product.variants.first.id }}" },
    { name: {{ section.settings.r4_product.title | default: 'Gift 4' | json }}, vid: "{{ section.settings.r4_product.variants.first.id }}" },
    { name: {{ section.settings.r5_product.title | default: 'Gift 5' | json }}, vid: "{{ section.settings.r5_product.variants.first.id }}" }
  ];

  const WEIGHTS = [0, 20, 20, 20, 20, 20]; 
  const MAX_SPINS = {{ section.settings.daily_spin_limit | default: 1 }};
  const MIN_ORDER = {{ section.settings.min_order_amount | default: 10000 }};
  const SLICE_CENTERS = [30, 90, 150, 210, 270, 330];

  let isSpinning = false;
  let currentRotation = 0;

  // ---- DROPDOWN PRIZES TOGGLE ----
  window.togglePrizes = function() {
    const list = document.getElementById('eiwsPrizesList');
    const btn = document.querySelector('.eiws-prizes-toggle-btn');
    if (list && btn) {
      list.classList.toggle('show');
      btn.classList.toggle('active');
    }
  };

  // ---- SPIN LIMIT CHECK (IP Tracking) ----
  document.addEventListener('DOMContentLoaded', async function() {
    const today = new Date().toLocaleDateString('en-IN');
    let userIP = 'unknown';
    
    // Fetch user IP quietly in the background
    try {
      const response = await fetch('https://api.ipify.org?format=json');
      const data = await response.json();
      userIP = data.ip;
    } catch (e) {
      console.warn('IP fetch failed, defaulting to standard device tracking.');
    }
    
    window.esponUserIP = userIP; // Save globally for the win function
    const storageKeyDate = `espon_spin_date_${userIP}`;
    const storageKeyCount = `espon_spin_count_${userIP}`;

    let savedDate  = localStorage.getItem(storageKeyDate) || localStorage.getItem('espon_spin_date');
    let savedCount = parseInt(localStorage.getItem(storageKeyCount) || localStorage.getItem('espon_spin_count')) || 0;

    if (savedDate !== today) {
      savedCount = 0;
      localStorage.setItem(storageKeyDate, today);
      localStorage.setItem('espon_spin_date', today);
      localStorage.setItem(storageKeyCount, '0');
      localStorage.setItem('espon_spin_count', '0');
    }

    const spinCenter = document.getElementById('eiwsSpinCenter');
    const actionDisplay = document.getElementById('eiwsActionDisplay');

    if (spinCenter && savedCount >= MAX_SPINS) {
      spinCenter.classList.add('disabled');
      spinCenter.innerHTML = '<i class="fas fa-clock"></i><span>DONE<br>TODAY</span>';
      spinCenter.onclick = null;

      if (actionDisplay) {
        actionDisplay.innerHTML = `
          <div class="eiws-used-banner">
            <i class="fas fa-clock-rotate-left"></i>
            You've used your ${MAX_SPINS} spin(s) for today.<br>Come back tomorrow!
          </div>`;
      }
    }
  });

  // ---- PICK WINNER ----
  function pickWinner() {
    const totalWeight = WEIGHTS.reduce((a, b) => a + b, 0);
    let rand = Math.random() * totalWeight;
    for (let i = 0; i < WEIGHTS.length; i++) {
      rand -= WEIGHTS[i];
      if (rand <= 0) return i;
    }
    return 1;
  }

  // ---- PARTICLE BURST ----
  function burstParticles(x, y) {
    const colors = ['#CA8A04', '#fbbf24', '#fff', '#f87171', '#4ade80'];
    for (let i = 0; i < 24; i++) {
      const p = document.createElement('div');
      p.className = 'eiws-particle';
      const angle = (Math.PI * 2 * i) / 24;
      const dist  = 80 + Math.random() * 120;
      p.style.cssText = `
        left: ${x}px; top: ${y}px;
        background: ${colors[i % colors.length]};
        --tx: ${Math.cos(angle) * dist}px;
        --ty: ${Math.sin(angle) * dist}px;
      `;
      document.body.appendChild(p);
      setTimeout(() => p.remove(), 1000);
    }
  }

  // ---- POINTER WIGGLE ----
  function wigglePointer() {
    const ptr = document.querySelector('.eiws-pointer-svg');
    if (!ptr) return;
    let wiggles = 0;
    const iv = setInterval(() => {
      const deg = (wiggles % 2 === 0) ? -12 : 12;
      ptr.style.transform = `rotate(${deg}deg)`;
      wiggles++;
      if (wiggles > 12) {
        ptr.style.transform = 'rotate(0deg)';
        clearInterval(iv);
      }
    }, 80);
  }

  // ---- MAIN SPIN ----
  window.eiwsStartSpin = function() {
    if (isSpinning) return;
    const spinCenter = document.getElementById('eiwsSpinCenter');
    if (!spinCenter || spinCenter.classList.contains('disabled')) return;

    isSpinning = true;
    spinCenter.innerHTML = '<i class="fas fa-sync fa-spin"></i><span>...</span>';
    spinCenter.classList.add('disabled');

    const winSlot   = pickWinner();
    const winner    = WHEEL_REWARDS[winSlot];

    const sliceCenter = SLICE_CENTERS[winSlot];
    const landAngle   = (360 - sliceCenter) % 360;
    const totalSpin   = currentRotation + 1800 + landAngle - (currentRotation % 360);

    setTimeout(wigglePointer, 3800);
    setTimeout(wigglePointer, 4200);

    gsap.to("#eiwsWheel", {
      rotation: totalSpin,
      duration: 5,
      ease: "power4.out",
      onUpdate: function() {
        currentRotation = gsap.getProperty("#eiwsWheel", "rotation");
      },
      onComplete: function() {
        currentRotation = totalSpin;
        isSpinning = false;

        const wheel = document.getElementById('eiwsWheel');
        if (wheel) {
          const rect = wheel.getBoundingClientRect();
          burstParticles(rect.left + rect.width / 2, rect.top + rect.height / 2);
        }

        addRewardToCart(winner, spinCenter);
      }
    });
  };

  // ---- ADD TO CART ----
  function addRewardToCart(winner, spinCenter) {
    if (!winner || !winner.vid || winner.vid === '') {
      alert('Reward configuration missing. Please contact support.');
      return;
    }

    const oldVid    = localStorage.getItem('espon_spin_reward_vid');
    const updates   = {};
    if (oldVid && oldVid !== winner.vid) updates[oldVid] = 0;
    updates[winner.vid] = 1;

    fetch(window.Shopify.routes.root + 'cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ updates })
    })
    .then(r => { if (!r.ok) throw new Error('Cart error'); return r.json(); })
    .then(() => {
      const expiry = Date.now() + 30 * 60 * 1000;
      localStorage.setItem('espon_spin_expiry', expiry);
      localStorage.setItem('espon_spin_reward_name', winner.name);
      localStorage.setItem('espon_spin_reward_vid', winner.vid);
      localStorage.setItem('espon_spin_min_order', MIN_ORDER);

      const today = new Date().toLocaleDateString('en-IN');
      const userIP = window.esponUserIP || 'unknown';
      const storageKeyDate = `espon_spin_date_${userIP}`;
      const storageKeyCount = `espon_spin_count_${userIP}`;
      
      const count = parseInt(localStorage.getItem(storageKeyCount) || localStorage.getItem('espon_spin_count') || '0') + 1;
      
      localStorage.setItem(storageKeyDate, today);
      localStorage.setItem(storageKeyCount, count);
      localStorage.setItem('espon_spin_date', today);
      localStorage.setItem('espon_spin_count', count);

      spinCenter.innerHTML = '<i class="fas fa-gift"></i><span>WON!</span>';
      spinCenter.style.background = 'linear-gradient(135deg,#16a34a,#22c55e)';
      spinCenter.style.color = '#fff';

      document.getElementById('eiwsWonText').innerText = winner.name;
      document.getElementById('eiwsWinOverlay').classList.add('show');

      document.documentElement.dispatchEvent(new CustomEvent('cart:change', { bubbles: true }));
      document.documentElement.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true }));
    })
    .catch(() => {
      alert('Error updating cart. Please try again.');
      spinCenter.classList.remove('disabled');
      spinCenter.innerHTML = '<i class="fas fa-bolt"></i><span>TAP<br>TO SPIN</span>';
      isSpinning = false;
    });
  }

})();
</script>

{% schema %}
{
  "name": "Espon Spin Wheel",
  "settings": [
    { "type": "header", "content": "⚙️ Spin Settings" },
    {
      "type": "number",
      "id": "min_order_amount",
      "label": "Min Order for Reward (₹)",
      "default": 10000
    },
    {
      "type": "range",
      "id": "daily_spin_limit",
      "min": 1, "max": 5, "step": 1,
      "label": "Daily Spins Per User",
      "default": 1
    },

    { "type": "header", "content": "👑 Mega Jackpot (Display Only — Never Wins)" },
    { "type": "image_picker", "id": "mega_image", "label": "Jackpot Prize Image" },
    { "type": "text",  "id": "mega_name",  "label": "Jackpot Prize Name",  "default": "iPhone 17 Pro Max" },
    { "type": "text",  "id": "mega_value", "label": "Jackpot Prize Value (₹)", "default": "1,34,900",
      "info": "Shown on the left panel for excitement only" },

    { "type": "header", "content": "🎁 Real Reward 1" },
    { "type": "product", "id": "r1_product", "label": "Product", "info": "Auto-grabs image, title & variant ID" },

    { "type": "header", "content": "🎁 Real Reward 2" },
    { "type": "product", "id": "r2_product", "label": "Product" },

    { "type": "header", "content": "🎁 Real Reward 3" },
    { "type": "product", "id": "r3_product", "label": "Product" },

    { "type": "header", "content": "🎁 Real Reward 4" },
    { "type": "product", "id": "r4_product", "label": "Product" },

    { "type": "header", "content": "🎁 Real Reward 5" },
    { "type": "product", "id": "r5_product", "label": "Product" }
  ],
  "presets": [{ "name": "Espon Spin Wheel" }]
}
{% endschema %}