<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  #shopify-section-{{ section.id }} {
    --navy: {{ section.settings.heading_color }};
    --gold-main: {{ section.settings.accent_color }};
    --border: {{ section.settings.border_color }};
    --bg-white: {{ section.settings.bg_color }};
    --text-muted: {{ section.settings.text_color }};
    --card-bg: {{ section.settings.card_bg_color }};
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: var(--bg-white);
  }

  /* --- ANIMATION --- */
  #shopify-section-{{ section.id }} .reveal-up {
    opacity: 0;
    transform: translateY(50px) translateZ(-50px) rotateX(-5deg);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #shopify-section-{{ section.id }} .reveal-up.active {
    opacity: 1;
    transform: translateY(0) translateZ(0) rotateX(0deg);
  }

  /* --- INVENTORY HEADER --- */
  #shopify-section-{{ section.id }} .inventory-header {
    padding: {{ section.settings.padding_top }}px 5% 0;
    display: flex; 
    justify-content: space-between; 
    align-items: flex-end; 
    margin-bottom: 40px;
  }

  #shopify-section-{{ section.id }} .inventory-header h2 {
    font-size: 2.5rem; 
    font-weight: 800; 
    color: var(--navy);
    margin: 0 0 5px 0;
    line-height: 1.1;
  }

  #shopify-section-{{ section.id }} .inventory-header p {
    color: var(--text-muted);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .inventory-header a {
    color: var(--gold-main); 
    font-weight: 800;
    text-decoration: none;
    transition: opacity 0.3s;
  }
  
  #shopify-section-{{ section.id }} .inventory-header a:hover {
    opacity: 0.8;
  }

  /* --- PRODUCT GRID --- */
  #shopify-section-{{ section.id }} .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    padding: 0 5% {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .b2b-product-card {
    background: var(--card-bg);
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: 0.3s;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
  }

  #shopify-section-{{ section.id }} .b2b-product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.1);
  }

  #shopify-section-{{ section.id }} .badge-b2b {
    background: var(--gold-main); 
    color: white; 
    display: inline-block; 
    padding: 5px 10px; 
    font-size: 0.7rem; 
    font-weight: 800; 
    margin: 10px; 
    border-radius: 5px;
  }

  #shopify-section-{{ section.id }} .card-details {
    padding: 20px;
  }

  #shopify-section-{{ section.id }} .card-details h4 {
    font-size: 1rem; 
    margin: 0 0 5px; 
    color: var(--navy);
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .price-row {
    display: flex; 
    justify-content: space-between; 
    align-items: center;
  }

  #shopify-section-{{ section.id }} .wholesale-label {
    color: var(--text-muted); 
    font-size: 0.8rem;
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .price-real { 
    color: var(--gold-main); 
    font-weight: 800; 
    font-size: 1.1rem; 
  }
  
  #shopify-section-{{ section.id }} .per-pc {
    font-size: 0.8em; 
    color: var(--text-muted); 
    font-weight: 600;
  }

  /* --- MOBILE OPTIMIZATION --- */
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .inventory-header {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      flex-direction: column;
      align-items: flex-start;
      gap: 15px;
      margin-bottom: 20px !important;
    }

    #shopify-section-{{ section.id }} .inventory-header h2 {
      font-size: 1.8rem;
    }

    #shopify-section-{{ section.id }} .product-grid { 
      grid-template-columns: repeat(2, 1fr) !important; 
      gap: 10px; 
      padding-left: 10px; 
      padding-right: 10px; 
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }
    
    #shopify-section-{{ section.id }} .card-details { 
      padding: 10px !important; 
    }
    
    #shopify-section-{{ section.id }} .card-details h4 { 
      font-size: 0.75rem !important; 
      margin-bottom: 5px !important; 
      white-space: nowrap; 
      overflow: hidden; 
      text-overflow: ellipsis; 
    }
    
    #shopify-section-{{ section.id }} .wholesale-label { 
      display: none; 
    }
    
    #shopify-section-{{ section.id }} .price-real { 
      font-size: 0.85rem !important; 
    }
  }
</style>

<div class="inventory-header">
  <div>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
  </div>
  {% if section.settings.view_all_text != blank %}
    <a href="{{ section.settings.view_all_link }}">{{ section.settings.view_all_text }}</a>
  {% endif %}
</div>

<div class="product-grid" id="inventory-grid-{{ section.id }}">
  {% assign display_count = 0 %}
  {% assign max_products = section.settings.product_limit %}
  {% assign target_collection = section.settings.collection %}
  {% assign skip_tag = section.settings.skip_tag %}
  
  {% if target_collection == blank %}
    {% assign target_collection = collections['all'] %}
  {% endif %}

  {% for product in target_collection.products limit: 50 %}
    
    {% comment %} --- SKIP HIDDEN GIFTS (Spinner Logic) --- {% endcomment %}
    {% if skip_tag != blank and product.tags contains skip_tag %}
      {% continue %}
    {% endif %}
    
    {% if display_count >= max_products %}
      {% break %}
    {% endif %}
    
    {% assign display_count = display_count | plus: 1 %}
  
    {% comment %} --- ESPON B2B MATH TRICK --- {% endcomment %}
    {% assign first_var = product.first_available_variant %}
    {% assign multiplier = 1 %}
    {% if first_var.title contains 'M to XXL' %}
      {% assign multiplier = 4 %}
    {% elsif first_var.title contains 'M to XL' %}
      {% assign multiplier = 3 %}
    {% elsif first_var.title contains 'L to XXL' %}
      {% assign multiplier = 3 %}
    {% elsif first_var.title contains 'S to XXL' %}
      {% assign multiplier = 5 %}
    {% elsif first_var.title contains '26-36' %}
      {% assign multiplier = 6 %}
    {% elsif first_var.title contains '32-36' %}
      {% assign multiplier = 3 %}
    {% endif %}
    {% assign piece_price = product.price | divided_by: multiplier %}

    <a href="{{ product.url }}" class="b2b-product-card reveal-up" style="display: block; text-decoration: none; color: inherit; cursor: pointer;">
      
      <div style="height: 250px; background: url('{{ product.featured_image | img_url: '600x' }}') center/cover no-repeat;">
        <div class="badge-b2b">{{ section.settings.badge_text }}</div>
      </div>
      
      <div class="card-details">
        <h4>{{ product.title }}</h4>
        
        <div class="AirReviews-Widget AirReviews-Widget--Stars" data-product-id="{{ product.id }}" style="margin-bottom: 10px; display: block;"></div>
        
        <div class="price-row">
          <span class="wholesale-label">{{ section.settings.wholesale_text }}</span>
          <span class="price-real">{{ piece_price | money }} <span class="per-pc">{{ section.settings.per_piece_text }}</span></span>
        </div>
      </div>
    </a>
  
  {% endfor %}
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });
    
    const elements = document.querySelectorAll('#inventory-grid-{{ section.id }} .reveal-up');
    elements.forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Espon Inventory",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "LIVE FACTORY STOCK"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Direct wholesale pricing per piece."
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Link Text",
      "default": "VIEW ALL &rarr;"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Product Grid Labels"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Product Badge Text",
      "default": "B2B"
    },
    {
      "type": "text",
      "id": "wholesale_text",
      "label": "Wholesale Label Text",
      "default": "WHOLESALE:"
    },
    {
      "type": "text",
      "id": "per_piece_text",
      "label": "Per Piece Text",
      "default": "/ pc"
    },
    {
      "type": "header",
      "content": "Data Source"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to Display"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 4,
      "max": 24,
      "step": 4,
      "label": "Number of Products to Show",
      "default": 8
    },
    {
      "type": "text",
      "id": "skip_tag",
      "label": "Tag to Hide (e.g. Spinner Gifts)",
      "default": "hidden-gift",
      "info": "Products with this tag will not show in the grid."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Gold)",
      "default": "#CA8A04"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color (Navy)",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Paragraph Text Color",
      "default": "#64748b"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card Border Color",
      "default": "#e2e8f0"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 50
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Espon Inventory"
    }
  ]
}
{% endschema %}