<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  .uk-marquee-container-{{ section.id }} {
    /* Dynamic Theme Editor Variables */
    --bg-color: {{ section.settings.bg_color | default: '#CA8A04' }};
    --text-color: {{ section.settings.text_color | default: '#ffffff' }};
    --speed: {{ section.settings.animation_speed | default: 25 }}s;
    --direction: normal;
    --padding-y: 3px;
    --font-size-desktop: 11px;
    --font-size-mobile: 9px;
    
    background-color: var(--bg-color);
    color: var(--text-color);
    padding: var(--padding-y) 0;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    height: 30px;
    z-index: 1;
    font-family: 'Plus Jakarta Sans', sans-serif;
    line-height: 1;
  }

  .uk-marquee-track {
    display: flex;
    white-space: nowrap;
    animation: uk-marquee-scroll var(--speed) linear infinite var(--direction);
  }

  .uk-marquee-container-{{ section.id }}:hover .uk-marquee-track {
    animation-play-state: paused;
  }

  .uk-marquee-content {
    display: flex;
    align-items: center;
    padding-right: 50px;
  }

  .uk-marquee-item {
    display: inline-flex;
    align-items: center;
    gap: {{ section.settings.icon_gap | default: 10 }}px;
    margin-right: {{ section.settings.item_gap | default: 40 }}px;
    font-size: var(--font-size-desktop);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1;
  }

  .uk-marquee-item i {
    font-size: calc(var(--font-size-desktop) + 2px);
    opacity: 0.8;
  }

  @keyframes uk-marquee-scroll {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-100%); }
  }

  @media screen and (max-width: 768px) {
    .uk-marquee-item {
      font-size: var(--font-size-mobile);
      margin-right: 25px;
    }
    .uk-marquee-item i {
      font-size: calc(var(--font-size-mobile) + 2px);
    }
    .uk-marquee-content {
      padding-right: 25px;
    }
  }
</style>

<div class="uk-marquee-container-{{ section.id }}">
  {% for track_loop in (1..4) %}
    <div class="uk-marquee-track" {% if track_loop > 1 %}aria-hidden="true"{% endif %}>
      <div class="uk-marquee-content">
        {%- for block in section.blocks -%}
          <div class="uk-marquee-item" {{ block.shopify_attributes }}>
            <span>{{ block.settings.text }}</span>
            {% if block.settings.icon_class != blank %}
              <i class="{{ block.settings.icon_class }}"></i>
            {% endif %}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Espon Marquee",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#CA8A04"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing & Animation"
    },
    {
      "type": "range",
      "id": "icon_gap",
      "min": 5,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Space between Text and Icon",
      "default": 10
    },
    {
      "type": "range",
      "id": "item_gap",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Space between Items",
      "default": 40
    },
    {
      "type": "range",
      "id": "animation_speed",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Scroll Speed",
      "default": 25
    }
  ],
  "blocks": [
    {
      "type": "marquee_item",
      "name": "Marquee Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "FREE SHIPPING ON ALL ORDERS"
        },
        {
          "type": "text",
          "id": "icon_class",
          "label": "FontAwesome Icon Class",
          "default": "fas fa-truck"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Espon Marquee",
      "blocks": [
        {
          "type": "marquee_item",
          "settings": {
            "text": "FREE SHIPPING ON ALL ORDERS",
            "icon_class": "fas fa-truck"
          }
        },
        {
          "type": "marquee_item",
          "settings": {
            "text": "FLAT 50% RETAIL MARGIN",
            "icon_class": "fas fa-star"
          }
        },
        {
          "type": "marquee_item",
          "settings": {
            "text": "5% CASHBACK ON EVERY ORDER",
            "icon_class": "fas fa-coins"
          }
        },
        {
          "type": "marquee_item",
          "settings": {
            "text": "EXPRESS DELIVERY",
            "icon_class": "fas fa-truck-fast"
          }
        },
        {
          "type": "marquee_item",
          "settings": {
            "text": "COD AVAILABLE (10% ADVANCE)",
            "icon_class": "fas fa-box-open"
          }
        },
        {
          "type": "marquee_item",
          "settings": {
            "text": "MOQ: 50 PCS",
            "icon_class": "fas fa-check-circle"
          }
        }
      ]
    }
  ]
}
{% endschema %}