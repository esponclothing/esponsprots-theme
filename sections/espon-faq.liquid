{% schema %}
{
  "name": "Esponsports FAQ",
  "settings": [],
  "presets": [
    {
      "name": "Esponsports FAQ"
    }
  ]
}
{% endschema %}

<style>
  .faq-container { font-family: 'Plus Jakarta Sans', sans-serif; max-width: 800px; margin: 0 auto; padding: 60px 20px; }
  .faq-item { background: #ffffff; border: 1px solid #e2e8f0; border-radius: 10px; margin-bottom: 15px; padding: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.03); }
  .faq-q { color: #0f172a; font-weight: 800; font-size: 1.1rem; margin-bottom: 10px; display: flex; align-items: center; }
  .faq-q::before { content: "Q."; color: #CA8A04; margin-right: 10px; font-size: 1.3rem; }
  .faq-a { color: #64748b; font-size: 0.95rem; line-height: 1.6; padding-left: 35px; }
</style>

<div class="faq-container">
  <h2 style="text-align: center; color: #0f172a; margin-bottom: 40px; font-weight: 800;">Frequently Asked Questions</h2>
  
  <div class="faq-item">
    <div class="faq-q">What is the Minimum Order Quantity (MOQ)?</div>
    <div class="faq-a">For wholesale pricing, our MOQ is <strong>50 pieces</strong>. You can mix and match different sizes and colors.</div>
  </div>
  
  <div class="faq-item">
    <div class="faq-q">Can I buy samples before a bulk order?</div>
    <div class="faq-a">Yes! We encourage new retailers to order a <strong>Sample Set (5-7 pieces)</strong> to check our fabric quality and stitching before placing a large order.</div>
  </div>
  
  <div class="faq-item">
    <div class="faq-q">Is Cash on Delivery (COD) available?</div>
    <div class="faq-a">Yes, COD is available for all retailers. You only need to pay a <strong>10% Advance</strong> to confirm the order, and the rest can be paid to the courier upon delivery.</div>
  </div>
  
  <div class="faq-item">
    <div class="faq-q">What fabrics do you use?</div>
    <div class="faq-a">We strictly use premium fabrics including <strong>Imported 4-Way Lycra (Heavy GSM), NS (Non-Stretchable), Twill, and Terry Lycra</strong>.</div>
  </div>
  
  <div class="faq-item">
    <div class="faq-q">Where is your factory located?</div>
    <div class="faq-a">Our manufacturing unit is located in <strong>Rohtak, Haryana (124001)</strong>. You are welcome to visit or request a live video call to see the stock.</div>
  </div>
</div>
