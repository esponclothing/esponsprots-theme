{% schema %}
{
  "name": "Esponsports FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need to know about partnering with Espon Sports."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f8fafc"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is the minimum order quantity?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Our minimum order amount is ₹10,000 to ensure wholesale pricing.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Esponsports FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "What is the minimum order requirement for B2B wholesale?",
            "answer": "<p>To access our premium B2B factory pricing with a flat 50% margin, we require a minimum order value of ₹10,000.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Are there any shipping charges?",
            "answer": "<p>No! We offer <strong>FREE SHIPPING ON ALL ORDERS</strong> across India to help our 5,000+ retailers and wholesalers maximize their profits.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How does the Wallet Cashback work?",
            "answer": "<p>You receive an instant 5% Cashback directly into your Esponsports Wallet on every order. This cashback can be fully utilized on your next wholesale purchase.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What is the Spin & Win Wheel?",
            "answer": "<p>Our unique Spin & Win rewards program gives you a chance to win mega prizes (like an iPhone 17 Pro, Smart Watches, or Massage Guns) on qualifying orders! You get 1 daily spin limit when you meet the minimum order requirements.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What type of products do you manufacture?",
            "answer": "<p>As India's Premium B2B Factory, we specialize in high-quality sports and activewear, including premium Track Pants, Shorts, and athletic apparel designed for comfort and durability.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Can I trust the quality of your fabrics?",
            "answer": "<p>Absolutely. We manufacture everything in-house in our premium factory, ensuring rigorous quality checks before dispatch. Our 50% flat margin structure means you get premium retail quality at factory prices.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  .espon-faq-section {
    padding: 60px 20px;
    background-color: {{ section.settings.bg_color }};
    font-family: 'Inter', sans-serif;
  }
  .espon-faq-container {
    max-width: 800px;
    margin: 0 auto;
  }
  .espon-faq-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .espon-faq-heading {
    font-size: 32px;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 12px;
  }
  .espon-faq-subheading {
    font-size: 16px;
    color: #64748b;
  }
  
  .espon-faq-item {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    margin-bottom: 16px;
    overflow: hidden;
    transition: all 0.3s ease;
  }
  .espon-faq-item:hover {
    border-color: #ca8a04;
    box-shadow: 0 4px 12px rgba(202, 138, 4, 0.08);
  }
  
  .espon-faq-question {
    padding: 20px 24px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    font-size: 16px;
    color: #0f172a;
    user-select: none;
  }
  .espon-faq-question .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #f1f5f9;
    color: #0f172a;
    transition: all 0.3s ease;
  }
  .espon-faq-item.active .espon-faq-question {
    color: #ca8a04;
  }
  .espon-faq-item.active .espon-faq-question .icon {
    background: #ca8a04;
    color: #ffffff;
    transform: rotate(180deg);
  }
  
  .espon-faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, padding 0.4s ease;
    background: #ffffff;
    padding: 0 24px;
    color: #475569;
    font-size: 15px;
    line-height: 1.6;
  }
  .espon-faq-item.active .espon-faq-answer {
    padding: 0 24px 24px 24px;
    max-height: 500px;
  }
</style>

<div class="espon-faq-section">
  <div class="espon-faq-container">
    <div class="espon-faq-header">
      <h2 class="espon-faq-heading">{{ section.settings.heading }}</h2>
      <p class="espon-faq-subheading">{{ section.settings.subheading }}</p>
    </div>
    
    <div class="espon-faq-list">
      {% for block in section.blocks %}
        <div class="espon-faq-item" {{ block.shopify_attributes }}>
          <div class="espon-faq-question" onclick="toggleFaq(this)">
            {{ block.settings.question }}
            <span class="icon"><i class="fas fa-chevron-down"></i></span>
          </div>
          <div class="espon-faq-answer">
            {{ block.settings.answer }}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  function toggleFaq(element) {
    const item = element.parentElement;
    const allItems = document.querySelectorAll('.espon-faq-item');
    
    // Close other items if you only want one open at a time
    allItems.forEach(i => {
      if (i !== item) {
        i.classList.remove('active');
      }
    });
    
    item.classList.toggle('active');
  }
</script>
