<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  #shopify-section-{{ section.id }} {
    --bg-color: {{ section.settings.bg_color }};
    --border: {{ section.settings.border_color }};
    --navy: {{ section.settings.heading_color }};
    --text-muted: {{ section.settings.text_color }};
    --badge-border: {{ section.settings.badge_border_color }};
    --badge-text: {{ section.settings.badge_text_color }};
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  /* --- LOGISTICS SECTION --- */
  #shopify-section-{{ section.id }} .logistics-bar { 
    padding: {{ section.settings.padding_top }}px 5% {{ section.settings.padding_bottom }}px; 
    text-align: center; 
    border-top: 1px solid var(--border); 
    background-color: var(--bg-color);
  }

  #shopify-section-{{ section.id }} .logistics-bar h3 {
    font-weight: 800; 
    font-size: 1.5rem; 
    margin: 0 0 20px 0; 
    color: var(--navy);
  }

  #shopify-section-{{ section.id }} .logistics-bar p {
    color: var(--text-muted);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .logistics-logos { 
    display: flex; 
    flex-wrap: wrap; 
    gap: 20px; 
    justify-content: center; 
    margin-top: 20px; 
  }

  #shopify-section-{{ section.id }} .log-badge { 
    border: 2px solid var(--badge-border); 
    padding: 8px 20px; 
    border-radius: 8px; 
    font-weight: 700; 
    color: var(--badge-text); 
    transition: all 0.3s ease;
  }

  #shopify-section-{{ section.id }} .log-badge:hover {
    border-color: var(--navy);
    color: var(--navy);
  }

  /* --- MOBILE OPTIMIZATION --- */
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .logistics-bar {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }
  }
</style>

<div class="logistics-bar">
  <h3>{{ section.settings.heading }}</h3>
  <p>{{ section.settings.description }}</p>
  
  <div class="logistics-logos">
    {%- for block in section.blocks -%}
      <span class="log-badge" {{ block.shopify_attributes }}>{{ block.settings.title }}</span>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Espon Logistics",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAST DELIVERY PARTNERS"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "We ensure your stock reaches you safely and on time."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Top Border Color",
      "default": "#e2e8f0"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color (Navy)",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Paragraph Text Color",
      "default": "#64748b"
    },
    {
      "type": "color",
      "id": "badge_border_color",
      "label": "Badge Border Color",
      "default": "#cbd5e1"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#475569"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "partner_badge",
      "name": "Partner Badge",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Partner Name",
          "default": "Blue Dart"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Espon Logistics",
      "blocks": [
        {
          "type": "partner_badge",
          "settings": { "title": "Blue Dart" }
        },
        {
          "type": "partner_badge",
          "settings": { "title": "Delhivery" }
        },
        {
          "type": "partner_badge",
          "settings": { "title": "VRL Logistics" }
        },
        {
          "type": "partner_badge",
          "settings": { "title": "TCI Express" }
        },
        {
          "type": "partner_badge",
          "settings": { "title": "DTDC" }
        },
        {
          "type": "partner_badge",
          "settings": { "title": "Om Logistics" }
        }
      ]
    }
  ]
}
{% endschema %}