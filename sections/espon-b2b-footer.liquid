<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  /* PERSISTENT MENU & BUTTONS */
  .ecp-persistent-menu { padding-bottom: 10px; display: flex; gap: 8px; overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
  .ecp-persistent-menu::-webkit-scrollbar { display: none; }
  .ecp-qr-btn { flex-shrink: 0; background: #f1f5f9; border: 1px solid #cbd5e1; color: #0f172a; padding: 6px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; cursor: pointer; transition: 0.2s; white-space: nowrap; font-family: inherit; }
  .ecp-qr-btn:hover { background: #0f172a; color: #CA8A04; border-color: #0f172a; }
  .ecp-submenu { display: none; gap: 8px; }
  .ecp-submenu.is-active { display: flex; }
  .ecp-clear-btn { background: none; border: none; color: #ef4444; font-size: 16px; cursor: pointer; transition: 0.2s; margin-right: 12px; }
  .ecp-clear-btn:hover { color: #dc2626; transform: scale(1.1); }
  .espon-footer-wrapper {
    background-color: #ffffff;
    color: #0f172a;
    font-family: 'Plus Jakarta Sans', sans-serif;
    padding: 80px 5% 40px;
    border-top: 1px solid #e2e8f0;
  }

  .espon-footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 50px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .footer-brand img {
    width: 120px; 
    height: auto; 
    margin-bottom: 25px;
    display: block;
  }

  .footer-brand p {
    color: #475569;
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: 350px;
  }

  .footer-col h4 {
    color: #0f172a;
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 1px;
    margin-bottom: 25px;
    text-transform: uppercase;
  }

  .footer-link {
    display: block;
    color: #475569;
    text-decoration: none;
    margin-bottom: 15px;
    font-size: 0.95rem;
    transition: 0.3s;
  }

  .footer-link:hover {
    color: #C28608;
    transform: translateX(5px);
  }

  .contact-link {
    display: flex;
    align-items: flex-start;
    gap: 15px;
    color: #475569;
    text-decoration: none;
    margin-bottom: 20px;
    font-size: 0.95rem;
    line-height: 1.5;
    transition: 0.3s;
  }

  .contact-link i { color: #C28608; margin-top: 4px; font-size: 1.1rem; }
  .contact-link:hover { color: #0f172a; }

  .footer-bottom {
    max-width: 1400px;
    margin: 60px auto 0;
    padding-top: 30px;
    border-top: 1px solid #e2e8f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  .copyright { color: #64748b; font-size: 0.85rem; }
  .social-icons { display: flex; gap: 20px; }
  .social-icons a { color: #0f172a; font-size: 1.2rem; transition: 0.3s; }
  .social-icons a:hover { color: #C28608; transform: translateY(-3px); }

  @media (max-width: 900px) {
    .espon-footer-grid { grid-template-columns: 1fr; gap: 40px; }
    .footer-bottom { flex-direction: column; text-align: center; }
    .footer-brand img { width: 100px; }
  }

  /* ==========================================
     ESPON AI HELPDESK WIDGET CSS
     ========================================== */
  .espo-mini-toggle {
    position: fixed;
    bottom: var(--wa-bottom-desk, 30px);
    background: linear-gradient(135deg, #0f172a, #1e293b);
    color: #CA8A04;
    border: 2px solid #CA8A04;
    width: 65px;
    height: 65px;
    border-radius: 50%;
    font-size: 26px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    z-index: 99998;
    transition: all 0.3s ease;
    animation: espoPulse 2s infinite;
  }
  .espo-mini-toggle.wa-pos-right { right: 30px; }
  .espo-mini-toggle.wa-pos-left { left: 30px; }
  
  .espo-mini-toggle:hover {
    transform: scale(1.1) translateY(-5px);
    box-shadow: 0 15px 30px rgba(202, 138, 4, 0.3);
    animation: none;
    color: #fff;
  }

  @keyframes espoPulse {
    0% { box-shadow: 0 0 0 0 rgba(202, 138, 4, 0.5); }
    70% { box-shadow: 0 0 0 15px rgba(202, 138, 4, 0); }
    100% { box-shadow: 0 0 0 0 rgba(202, 138, 4, 0); }
  }

  .espo-chat-popup {
    position: fixed;
    bottom: calc(var(--wa-bottom-desk, 30px) + 85px);
    width: 360px;
    height: 550px;
    background: #ffffff;
    border-radius: 20px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-family: 'Plus Jakarta Sans', sans-serif;
    z-index: 99999;
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px) scale(0.95);
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .espo-chat-popup.wa-pos-right { right: 30px; transform-origin: bottom right; }
  .espo-chat-popup.wa-pos-left { left: 30px; transform-origin: bottom left; }
  .espo-chat-popup.is-open { opacity: 1; pointer-events: auto; transform: translateY(0) scale(1); }

  .ecp-header { background: #0f172a; color: #fff; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; font-weight: 800; font-size: 16px; border-bottom: 3px solid #CA8A04; }
  .ecp-close { background: none; border: none; color: #94a3b8; font-size: 24px; cursor: pointer; line-height: 1; transition: 0.2s; }
  .ecp-close:hover { color: #fff; }
  .ecp-body { flex: 1; padding: 15px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; background: #f1f5f9; }
  
  .ecp-msg { max-width: 85%; padding: 12px 15px; border-radius: 12px; font-size: 13px; line-height: 1.5; font-weight: 600; }
  .ecp-msg-ai { background: #fff; color: #0f172a; align-self: flex-start; border-bottom-left-radius: 4px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; }
  .ecp-msg-user { background: #CA8A04; color: #fff; align-self: flex-end; border-bottom-right-radius: 4px; box-shadow: 0 2px 5px rgba(202, 138, 4, 0.2); }

  /* INPUT AREA WITH MIC */
  .ecp-input-area { padding: 10px 15px; background: #fff; border-top: 1px solid #e2e8f0; display: flex; flex-direction: column; gap: 10px; }
  .ecp-input-row { display: flex; gap: 8px; align-items: center; }
  
  .ecp-input { flex: 1; padding: 10px 15px; border-radius: 30px; border: 1px solid #cbd5e1; font-family: inherit; font-size: 13px; outline: none; }
  .ecp-input:focus { border-color: #0f172a; }
  
  .ecp-mic { background: #f1f5f9; border: 1px solid #cbd5e1; color: #0f172a; width: 38px; height: 38px; border-radius: 50%; cursor: pointer; font-size: 14px; transition: 0.3s; display: flex; align-items: center; justify-content: center; }
  .ecp-mic:hover { background: #e2e8f0; }
  .ecp-mic.recording { background: #ef4444; color: #fff; border-color: #ef4444; animation: pulse-red 1.5s infinite; }
  
  .ecp-send { background: #0f172a; color: #CA8A04; border: none; width: 38px; height: 38px; border-radius: 50%; cursor: pointer; font-size: 14px; transition: 0.2s; display: flex; align-items: center; justify-content: center; }
  .ecp-send:hover { transform: scale(1.05); background: #1e293b; }

  @keyframes pulse-red { 0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); } 70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); } 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); } }

  .ecp-wa-footer-btn { background: #25D366; color: #fff; text-decoration: none; font-size: 13px; font-weight: 700; padding: 10px; border-radius: 8px; display: flex; align-items: center; justify-content: center; gap: 8px; transition: 0.2s; text-transform: uppercase; letter-spacing: 0.5px; }
  .ecp-wa-footer-btn:hover { background: #1EBE55; transform: translateY(-2px); color: #fff; }

  .ecp-dots { display: flex; gap: 4px; align-items: center; padding: 5px 0; }
  .ecp-dots span { width: 6px; height: 6px; background: #0f172a; border-radius: 50%; animation: ecpBlink 1.4s infinite both; }
  .ecp-dots span:nth-child(2) { animation-delay: 0.2s; }
  .ecp-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes ecpBlink { 0%, 80%, 100% { opacity: 0.2; } 40% { opacity: 1; } }

  /* CAROUSEL FOR N8N PRODUCTS */
  .espo-carousel { display: flex !important; flex-direction: row !important; flex-wrap: nowrap !important; gap: 10px; overflow-x: auto !important; padding-bottom: 10px; margin-top: 10px; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; width: 100%; }
  .espo-carousel::-webkit-scrollbar { height: 6px; }
  .espo-carousel::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
  .espo-card { min-width: 140px !important; max-width: 140px !important; background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; text-decoration: none !important; color: #0f172a !important; scroll-snap-align: start; flex-shrink: 0 !important; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.05); display: flex; flex-direction: column; transition: transform 0.2s; }
  .espo-card:hover { transform: translateY(-3px); border-color: #CA8A04; }
  .espo-card img { width: 100%; height: 140px; object-fit: cover; border-bottom: 1px solid #e2e8f0; }
  .espo-card-info { padding: 10px; display: flex; flex-direction: column; gap: 4px; }
  .espo-card-info h4 { font-size: 11px !important; margin: 0 !important; font-weight: 700 !important; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.3;}
  .espo-price { font-size: 13px !important; font-weight: 900 !important; color: #CA8A04 !important; margin: 0 !important; }

  /* AI INLINE WA BUTTON */
  .ai-wa-btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; background: #25D366; color: #fff !important; text-decoration: none !important; padding: 10px 16px; border-radius: 8px; font-weight: 800; font-size: 13px; margin-top: 10px; text-transform: uppercase; letter-spacing: 0.5px; box-shadow: 0 4px 10px rgba(37, 211, 102, 0.3); transition: 0.2s; }
  .ai-wa-btn:hover { background: #1EBE55; transform: translateY(-2px); color:#fff; }

  /* CHATBOT PILLS & ATC */
  .ecp-pill-container { display: flex; gap: 8px; padding-bottom: 15px; flex-wrap: wrap; margin-left: 10px; }
  .ecp-pill-btn { background: #f8fafc; border: 1px solid #cbd5e1; color: #475569; padding: 6px 14px; border-radius: 20px; font-size: 11.5px; cursor: pointer; transition: 0.2s; font-weight: 600; font-family: inherit; }
  .ecp-pill-btn:hover { background: #e2e8f0; color: #0f172a; border-color: #94a3b8; }
  .espo-atc-btn { background: #0f172a; color: #fff; border: none; padding: 8px; margin: 0 10px 10px; border-radius: 6px; font-size: 11px; cursor: pointer; font-weight: bold; transition: 0.2s; text-align: center; font-family: inherit; }
  .espo-atc-btn:hover { background: #CA8A04; color: #fff; }

  @media (max-width: 768px) {
    .espo-mini-toggle { width: 55px; height: 55px; font-size: 22px; bottom: var(--wa-bottom-mob, 20px); }
    .espo-mini-toggle.wa-pos-right { right: 20px; }
    .espo-mini-toggle.wa-pos-left { left: 20px; }

    .espo-chat-popup { bottom: calc(var(--wa-bottom-mob, 20px) + 70px); width: calc(100vw - 40px); height: 480px; }
    .espo-chat-popup.wa-pos-right { right: 20px; }
    .espo-chat-popup.wa-pos-left { left: 20px; }
  }
</style>

<footer class="espon-footer-wrapper">
  <div class="espon-footer-grid">
    <div class="footer-brand">
      {% if section.settings.footer_logo != blank %}
        <img src="{{ section.settings.footer_logo | img_url: '400x' }}" alt="{{ shop.name }}">
      {% else %}
        <img src="https://cdn.shopify.com/s/files/1/0992/9231/5780/files/Untitled_design_3.gif?v=1771232016" alt="Espon Sports">
      {% endif %}
      <p>{{ section.settings.footer_desc }}</p>
    </div>

    <div class="footer-col">
      <h4>{{ section.settings.col1_title }}</h4>
      {% if section.settings.col1_link1_text != blank %}<a href="{{ section.settings.col1_link1_url }}" class="footer-link">{{ section.settings.col1_link1_text }}</a>{% endif %}
      {% if section.settings.col1_link2_text != blank %}<a href="{{ section.settings.col1_link2_url }}" class="footer-link">{{ section.settings.col1_link2_text }}</a>{% endif %}
      {% if section.settings.col1_link3_text != blank %}<a href="{{ section.settings.col1_link3_url }}" class="footer-link">{{ section.settings.col1_link3_text }}</a>{% endif %}
      {% if section.settings.col1_link4_text != blank %}<a href="{{ section.settings.col1_link4_url }}" class="footer-link">{{ section.settings.col1_link4_text }}</a>{% endif %}
    </div>

    <div class="footer-col">
      <h4>{{ section.settings.col2_title }}</h4>
      {% if section.settings.col2_link1_text != blank %}<a href="{{ section.settings.col2_link1_url }}" class="footer-link">{{ section.settings.col2_link1_text }}</a>{% endif %}
      {% if section.settings.col2_link2_text != blank %}<a href="{{ section.settings.col2_link2_url }}" class="footer-link">{{ section.settings.col2_link2_text }}</a>{% endif %}
      {% if section.settings.col2_link3_text != blank %}<a href="{{ section.settings.col2_link3_url }}" class="footer-link">{{ section.settings.col2_link3_text }}</a>{% endif %}
      {% if section.settings.col2_link4_text != blank %}<a href="{{ section.settings.col2_link4_url }}" class="footer-link">{{ section.settings.col2_link4_text }}</a>{% endif %}
      {% if section.settings.col2_link5_text != blank %}<a href="{{ section.settings.col2_link5_url }}" class="footer-link">{{ section.settings.col2_link5_text }}</a>{% endif %}
    </div>

    <div class="footer-col">
      <h4>{{ section.settings.contact_title }}</h4>
      {% if section.settings.contact_address != blank %}<a href="{{ section.settings.contact_map_link }}" target="_blank" class="contact-link"><i class="fas fa-map-marker-alt"></i><span>{{ section.settings.contact_address }}</span></a>{% endif %}
      {% if section.settings.contact_email != blank %}<a href="mailto:{{ section.settings.contact_email }}" class="contact-link"><i class="fas fa-envelope"></i><span>{{ section.settings.contact_email }}</span></a>{% endif %}
      {% if section.settings.contact_phone != blank %}<a href="https://wa.me/{{ section.settings.contact_phone | remove: '+' | remove: ' ' | remove: '-' }}" target="_blank" class="contact-link"><i class="fab fa-whatsapp"></i><span>{{ section.settings.contact_phone }}</span></a>{% endif %}
    </div>
  </div>

  <div class="footer-bottom">
    <div class="copyright">&copy; {{ 'now' | date: "%Y" }} {{ section.settings.copyright_text }}. All Rights Reserved.</div>
    <div class="social-icons">
      {% if section.settings.social_instagram != blank %}<a href="{{ section.settings.social_instagram }}" target="_blank"><i class="fab fa-instagram"></i></a>{% endif %}
      {% if section.settings.social_facebook != blank %}<a href="{{ section.settings.social_facebook }}" target="_blank"><i class="fab fa-facebook"></i></a>{% endif %}
      {% if section.settings.social_google != blank %}<a href="{{ section.settings.social_google }}" target="_blank"><i class="fab fa-google"></i></a>{% endif %}
    </div>
  </div>
</footer>

{% if section.settings.enable_wa_widget %}
  {% assign clean_wa_num = section.settings.wa_widget_number | remove: '+' | remove: ' ' | remove: '-' %}
  {% assign encoded_msg = section.settings.wa_widget_message | url_encode %}

  <button class="espo-mini-toggle wa-pos-{{ section.settings.wa_widget_position }}" id="espoToggleBtn" style="--wa-bottom-desk: {{ section.settings.wa_bottom_desktop }}px; --wa-bottom-mob: {{ section.settings.wa_bottom_mobile }}px;" aria-label="Open Helpdesk">
    <i class="fa-solid {{ section.settings.ai_widget_icon | default: 'fa-headset' }}"></i>
  </button>

  <div class="espo-chat-popup wa-pos-{{ section.settings.wa_widget_position }}" id="espoChatWindow" style="--wa-bottom-desk: {{ section.settings.wa_bottom_desktop }}px; --wa-bottom-mob: {{ section.settings.wa_bottom_mobile }}px;">
    <div class="ecp-header">
      <div style="display:flex; align-items:center; gap:8px;">
        <i class="fa-solid {{ section.settings.ai_widget_icon | default: 'fa-headset' }}" style="color: #CA8A04;"></i> Espon AI
      </div>
      <div>
        <button class="ecp-clear-btn" id="espoClearBtn" title="Clear Chat History"><i class="fa-solid fa-trash-can"></i></button>
        <button class="ecp-close" id="espoCloseBtn">&times;</button>
      </div>
    </div>

    <div class="ecp-body" id="ecpChatBody">
      </div>

    <div class="ecp-input-area">
      <div class="ecp-persistent-menu" id="espoMenuContainer">
        <div class="ecp-main-menu" id="espoMainMenu" style="display:flex; gap:8px;">
          <button class="ecp-qr-btn" onclick="sendQuickReply('Track Order')">📍 Track Order</button>
          <button class="ecp-qr-btn" onclick="sendQuickReply('Top 5 Articles')">⭐ Top 5</button>
          <button class="ecp-qr-btn" onclick="sendQuickReply('Offers')">🎁 Offers</button>
          <button class="ecp-qr-btn" onclick="toggleSubMenu('fabrics')">🧵 Fabrics ▾</button>
          <button class="ecp-qr-btn" onclick="toggleSubMenu('categories')">👕 Categories ▾</button>
        </div>
        <div class="ecp-submenu" id="espoFabricsMenu">
          <button class="ecp-qr-btn" onclick="toggleSubMenu('main')">⬅ Back</button>
          <button class="ecp-qr-btn" onclick="sendQuickReply('NS Fabric')">NS Fabric</button>
          <button class="ecp-qr-btn" onclick="sendQuickReply('Terry Fabric')">Terry Fabric</button>
          <button class="ecp-qr-btn" onclick="sendQuickReply('Lycra Fabric')">Lycra Fabric</button>
        </div>
        <div class="ecp-submenu" id="espoCategoriesMenu">
          <button class="ecp-qr-btn" onclick="toggleSubMenu('main')">⬅ Back</button>
          <button class="ecp-qr-btn" onclick="sendQuickReply('Shorts')">🩳 Shorts</button>
          <button class="ecp-qr-btn" onclick="sendQuickReply('Track Pants')">👖 Track Pants</button>
        </div>
      </div>

      <div class="ecp-input-row">
        <input type="text" id="ecpInput" class="ecp-input" placeholder="Type or speak...">
        <button class="ecp-mic" id="espoMicBtn" title="Tap to Speak"><i class="fa-solid fa-microphone"></i></button>
        <button class="ecp-send" id="ecpSendBtn"><i class="fa-solid fa-paper-plane"></i></button>
      </div>
      
      <a href="https://wa.me/{{ clean_wa_num }}?text={{ encoded_msg }}" target="_blank" class="ecp-wa-footer-btn">
        <i class="fa-brands fa-whatsapp"></i> Chat On Whatsapp
      </a>
    </div>
  </div>

  <script>
  document.addEventListener('DOMContentLoaded', function() {
    const toggleBtn = document.getElementById('espoToggleBtn');
    const closeBtn = document.getElementById('espoCloseBtn');
    const chatWindow = document.getElementById('espoChatWindow');
    const chatBody = document.getElementById('ecpChatBody');
    const chatInput = document.getElementById('ecpInput');
    const sendBtn = document.getElementById('ecpSendBtn');
    const micBtn = document.getElementById('espoMicBtn');
    const clearBtn = document.getElementById('espoClearBtn');

    if(!toggleBtn || !chatWindow) return;
    const iconClass = "{{ section.settings.ai_widget_icon | default: 'fa-headset' | escape }}";

    // --- AUTO-DETECT LOGGED IN USER ---
    {% if customer %}
      {% assign cust_phone = customer.phone %}
      {% if cust_phone == blank and customer.default_address.phone != blank %}
        {% assign cust_phone = customer.default_address.phone %}
      {% endif %}
      let rawPhone = "{{ cust_phone | remove: '+' | remove: ' ' | remove: '-' }}";
      if (rawPhone.length > 10) rawPhone = rawPhone.slice(-10);
      const loggedInPhone = rawPhone;
    {% else %}
      const loggedInPhone = "";
    {% endif %}

    // --- MEMORY: SESSION & HISTORY (Persistent) ---
    let sessionId = localStorage.getItem('espoSessionId') || 'espo-' + Math.random().toString(36).substr(2, 9);
    localStorage.setItem('espoSessionId', sessionId);

    let chatHistory = JSON.parse(localStorage.getItem('espoChatHistory')) || [];
    
    function renderHistory() {
      chatBody.innerHTML = '';
      if (chatHistory.length === 0) {
        const greet = "Hi! I'm Espo. How can I help you with bulk orders today?";
        chatHistory.push({ role: 'ai', content: greet });
      }
      chatHistory.forEach(msg => {
        const msgDiv = document.createElement('div');
        msgDiv.className = `ecp-msg ecp-msg-${msg.role}`;
        msgDiv.innerHTML = msg.content;
        chatBody.appendChild(msgDiv);
      });
      chatBody.scrollTop = chatBody.scrollHeight;
    }
    renderHistory();

    function saveMessage(role, content) {
      chatHistory.push({ role, content });
      localStorage.setItem('espoChatHistory', JSON.stringify(chatHistory));
    }

    // --- MEMORY: WINDOW STATE ---
    if (localStorage.getItem('espoChatOpen') === 'true') {
      chatWindow.classList.add('is-open');
      toggleBtn.innerHTML = '<i class="fa-solid fa-xmark"></i>';
      setTimeout(() => { chatBody.scrollTop = chatBody.scrollHeight; }, 500);
    }

    function toggleChat() {
      const isOpen = chatWindow.classList.toggle('is-open');
      localStorage.setItem('espoChatOpen', isOpen);
      toggleBtn.innerHTML = isOpen ? '<i class="fa-solid fa-xmark"></i>' : `<i class="fa-solid ${iconClass}"></i>`;
      if(isOpen) {
        setTimeout(() => chatInput.focus(), 300);
        chatBody.scrollTop = chatBody.scrollHeight;
      }
    }
    toggleBtn.addEventListener('click', toggleChat);
    closeBtn.addEventListener('click', toggleChat);

    // --- STT (Microphone) ---
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    if(SpeechRecognition) {
      const recognition = new SpeechRecognition();
      recognition.lang = navigator.language; 
      micBtn.addEventListener('click', () => recognition.start());
      recognition.onstart = () => micBtn.classList.add('recording');
      recognition.onresult = (e) => { chatInput.value = e.results[0][0].transcript; sendMessage(); };
      recognition.onend = () => micBtn.classList.remove('recording');
    }

    // --- SEND TO N8N (WITH URL FIX, MEMORY & PHONE VALIDATION) ---
    async function sendMessage() {
      const text = chatInput.value.trim();
      if(!text) return;

      // Clear any existing follow-up pills
      document.querySelectorAll('.ecp-pill-container').forEach(el => el.remove());

      // --- NEW: Phone Number Intercept Logic ---
      const isAwaitingPhone = localStorage.getItem('espoAwaitingPhone') === 'true';
      let payloadText = text;

      if (isAwaitingPhone) {
        // Ensure they typed at least 10 digits
        const digitsOnly = text.replace(/\D/g, '');
        if (digitsOnly.length < 10) {
          const errorMsg = document.createElement('div');
          errorMsg.className = 'ecp-msg ecp-msg-ai';
          errorMsg.innerHTML = "Please enter a valid 10-digit mobile number.";
          chatBody.appendChild(errorMsg);
          chatBody.scrollTop = chatBody.scrollHeight;
          return; // Stop here, wait for them to try again
        }
        
        // Valid number! Reset the text box back to normal chat mode
        localStorage.removeItem('espoAwaitingPhone');
        chatInput.type = "text";
        chatInput.placeholder = "Type or speak...";
        
        // Add a secret prefix so your n8n Switch Node catches it instantly
        payloadText = "TRACK_ORDER_PHONE: " + digitsOnly;
      }

      // Display the user's message visually
      if (!text.startsWith("TRACK_ORDER_PHONE:")) {
        const userMsg = document.createElement('div');
        userMsg.className = 'ecp-msg ecp-msg-user';
        userMsg.textContent = text; 
        chatBody.appendChild(userMsg);
        saveMessage('user', text);
      }
      
      chatInput.value = '';
      chatBody.scrollTop = chatBody.scrollHeight;

      const typing = document.createElement('div');
      typing.className = 'ecp-msg ecp-msg-ai';
      typing.innerHTML = '<div class="ecp-dots"><span></span><span></span><span></span></div>';
      chatBody.appendChild(typing);
      chatBody.scrollTop = chatBody.scrollHeight;

      try {
        // Send the payload (which contains the secret tag if it's a tracking number)
        const cleanText = payloadText.replace(/<[^>]*>?/gm, ''); 
        const response = await fetch(`https://n8n.srv1468559.hstgr.cloud/webhook/090f12f6-a1c8-470c-83b0-f2b3bcab377e?chatInput=${encodeURIComponent(cleanText)}&sessionId=${sessionId}`);
        const data = await response.text();
        if(typing.parentNode) chatBody.removeChild(typing);
        
        let finalMsg = "";
        try {
          const parsed = JSON.parse(data);
          let rawText = parsed[0]?.output || parsed.output || data;
          finalMsg = rawText.replace(/esponsports\.in/g, "esponsports.com");
        } catch(e) { 
          finalMsg = data.replace(/esponsports\.in/g, "esponsports.com"); 
        }

        // PREVENT WHATSAPP BUTTON SPAM
        const contactKeywords = ['contact', 'human', 'agent', 'support', 'talk', 'whatsapp', 'call'];
        const isContactIntent = contactKeywords.some(kw => text.toLowerCase().includes(kw));

        // FIX: n8n sends each product in its own <div class="espo-carousel">, causing them to stack. 
        // We need to merge them all into the FIRST carousel container.
        let tempDiv = document.createElement('div');
        tempDiv.innerHTML = finalMsg;

        if (!isContactIntent) {
          tempDiv.querySelectorAll('.ai-wa-btn').forEach(btn => btn.remove());
          tempDiv.innerHTML = tempDiv.innerHTML.replace(/<br>\s*(<\/div>)?\s*$/, '$1');
        }
        let carousels = tempDiv.querySelectorAll('.espo-carousel');
        if (carousels.length > 1) {
          let firstCarousel = carousels[0];
          for (let i = 1; i < carousels.length; i++) {
            while (carousels[i].firstChild) {
              firstCarousel.appendChild(carousels[i].firstChild);
            }
            carousels[i].remove();
          }
        }
        
        // ADD TO CART INJECTION
        tempDiv.querySelectorAll('.espo-card').forEach(card => {
          try {
             let url = new URL(card.href);
             let segments = url.pathname.split('/');
             let handle = segments[segments.length - 1];
             if(handle) {
                const btn = document.createElement('button');
                btn.className = 'espo-atc-btn';
                btn.innerHTML = 'Add to Cart';
                btn.onclick = function(e) { window.addEspoCart(e, handle); };
                card.appendChild(btn);
             }
          } catch(e) {}
        });
        
        finalMsg = tempDiv.innerHTML;

        const aiMsg = document.createElement('div');
        aiMsg.className = 'ecp-msg ecp-msg-ai';
        aiMsg.innerHTML = finalMsg;
        chatBody.appendChild(aiMsg);
        
        saveMessage('ai', finalMsg);
        
        // FOLLOW-UP PILLS
        const followUps = ["What colors do you have?", "What is the minimum order quantity?", "Do you offer custom branding?", "How fast is shipping?"];
        const shuffled = followUps.sort(() => 0.5 - Math.random());
        const selectedPills = shuffled.slice(0, 2);
        const pillContainer = document.createElement('div');
        pillContainer.className = 'ecp-pill-container';
        pillContainer.innerHTML = selectedPills.map(p => `<button class="ecp-pill-btn" onclick="sendQuickReply('${p}')">${p}</button>`).join('');
        chatBody.appendChild(pillContainer);
        chatBody.scrollTop = chatBody.scrollHeight;
      } catch (err) { 
        if(typing.parentNode) chatBody.removeChild(typing); 
      }
    }

// --- CLEAR CHAT LOGIC ---
    clearBtn.addEventListener('click', () => {
      if(confirm("Are you sure you want to clear the chat history?")) {
        localStorage.removeItem('espoChatHistory');
        localStorage.removeItem('espoAwaitingPhone');
        chatHistory = [];
        chatInput.type = "text";
        chatInput.placeholder = "Type or speak...";
        renderHistory();
      }
    });

    // --- SUB-MENU TOGGLE LOGIC ---
    window.toggleSubMenu = function(menu) {
      document.getElementById('espoMainMenu').style.display = 'none';
      document.getElementById('espoFabricsMenu').classList.remove('is-active');
      document.getElementById('espoCategoriesMenu').classList.remove('is-active');
      
      if(menu === 'main') {
        document.getElementById('espoMainMenu').style.display = 'flex';
      } else if(menu === 'fabrics') {
        document.getElementById('espoFabricsMenu').classList.add('is-active');
      } else if(menu === 'categories') {
        document.getElementById('espoCategoriesMenu').classList.add('is-active');
      }
    };

    // Global function for Quick Replies
    window.sendQuickReply = function(text) {
      // Return to main menu if clicked from a submenu
      toggleSubMenu('main');
      
      if (text === 'Track Order') {
        // 1. Show the user clicked Track Order
        const userMsg = document.createElement('div');
        userMsg.className = 'ecp-msg ecp-msg-user';
        userMsg.textContent = "📍 Track Order";
        chatBody.appendChild(userMsg);
        saveMessage('user', "📍 Track Order");
        chatBody.scrollTop = chatBody.scrollHeight;

        if (typeof loggedInPhone !== 'undefined' && loggedInPhone && loggedInPhone.length >= 10) {
          // Auto-track for logged in user
          chatInput.value = "TRACK_ORDER_PHONE: " + loggedInPhone;
          sendMessage();
          return;
        }

        // 2. Make Espo ask for the number instantly (Zero delay!)
        setTimeout(() => {
          const aiText = "I can certainly help you track your order! Please enter your 10-digit registered mobile number below:";
          const aiMsg = document.createElement('div');
          aiMsg.className = 'ecp-msg ecp-msg-ai';
          aiMsg.textContent = aiText;
          chatBody.appendChild(aiMsg);
          saveMessage('ai', aiText);
          chatBody.scrollTop = chatBody.scrollHeight;
          
          // 3. Change the input box to a Number Pad
          chatInput.type = "tel";
          chatInput.placeholder = "Enter mobile number here...";
          chatInput.focus();
          
          // 4. Tell the system we are waiting for a phone number
          localStorage.setItem('espoAwaitingPhone', 'true');
        }, 400);

      } else {
        // For all other buttons (Shorts, Top 5, etc)
        chatInput.value = text;
        sendMessage();
      }
    };

    sendBtn.addEventListener('click', sendMessage);
    chatInput.addEventListener('keypress', (e) => { if(e.key === 'Enter') sendMessage(); });
  });

  window.addEspoCart = async function(e, handle) {
      e.preventDefault();
      const btn = e.target;
      if (btn.disabled) return;
      btn.innerHTML = 'Adding...';
      btn.disabled = true;
      try {
          const res = await fetch('/products/' + handle + '.js');
          const product = await res.json();
          const variantId = product.variants[0].id;
          await fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: variantId, quantity: 1 })
          });
          btn.innerHTML = '✅ Added';
          btn.style.background = '#16a34a';
          setTimeout(() => { btn.innerHTML = 'Add to Cart'; btn.style.background = ''; btn.disabled = false; }, 2000);
          
          if (document.documentElement.dispatchEvent) {
            document.documentElement.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true }));
          }
      } catch (err) {
          btn.innerHTML = 'Error';
          setTimeout(() => { btn.innerHTML = 'Add to Cart'; btn.disabled = false; }, 2000);
      }
  };
  </script>
{% endif %}

