<script>

  /* --- RIPPLE EFFECT FOR ADD TO CART --- */
  function addRipple(e, btn) {
    const circle = document.createElement('span');
    const diameter = Math.max(btn.clientWidth, btn.clientHeight);
    const radius = diameter / 2;
    const rect = btn.getBoundingClientRect();
    circle.style.width = circle.style.height = diameter + 'px';
    circle.style.left = (e.clientX - rect.left - radius) + 'px';
    circle.style.top = (e.clientY - rect.top - radius) + 'px';
    circle.classList.add('ripple');
    const existing = btn.querySelector('.ripple');
    if (existing) existing.remove();
    btn.appendChild(circle);
  }

  /* --- GALLERY LOGIC --- */
  let currentIndex = 0;
  let autoSwipeInterval;

  function startAutoSwipe() {
    clearInterval(autoSwipeInterval); 
    // Pulls swipe speed from theme editor, converts seconds to milliseconds
    let swipeSpeed = {{ section.settings.gallery_swipe_speed | default: 3 }} * 1000;
    
    autoSwipeInterval = setInterval(() => {
      currentIndex = (currentIndex + 1) % productImages.length;
      updateMainImage(currentIndex);
    }, swipeSpeed); 
  }

  function updateMainImage(index) {
    const imgElement = document.getElementById('MainImg');
    imgElement.style.opacity = 0; 
    setTimeout(() => {
      imgElement.src = productImages[index];
      imgElement.style.opacity = 1; 
    }, 300);
  }

  function manualChangeImage(src, index) {
    currentIndex = index;
    const imgElement = document.getElementById('MainImg');
    imgElement.src = src; 
    startAutoSwipe(); 
  }

  /* --- MOBILE SWIPE LOGIC --- */
  let touchStartX = 0;
  let touchEndX = 0;

  // Grab the image frame container
  const imageFrame = document.querySelector('.main-image-frame');
  
  if (imageFrame) {
    // Record where the user puts their finger down
    imageFrame.addEventListener('touchstart', e => {
      touchStartX = e.changedTouches[0].screenX;
      clearInterval(autoSwipeInterval); // Pause auto-swipe while they are touching
    }, {passive: true});

    // Record where the user lifts their finger up
    imageFrame.addEventListener('touchend', e => {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
    }, {passive: true});
  }

  function handleSwipe() {
    const swipeThreshold = 40; // Minimum distance (in pixels) to trigger a swipe
    
    if (touchStartX - touchEndX > swipeThreshold) {
      // Swiped Left <--- (Go to Next Image)
      currentIndex = (currentIndex + 1) % productImages.length;
      updateMainImage(currentIndex);
      startAutoSwipe(); 
    }
    
    if (touchEndX - touchStartX > swipeThreshold) {
      // Swiped Right ---> (Go to Previous Image)
      currentIndex = (currentIndex - 1 + productImages.length) % productImages.length;
      updateMainImage(currentIndex);
      startAutoSwipe(); 
    }
  }

  /* --- DYNAMIC BUILDER LOGIC --- */
  const setMultipliers = {
    "M to XXL": 4, "M to XL": 3, "L to XXL": 3, "S to XXL": 5, "26-36": 6, "32-36": 3
  };

  function formatMoney(cents) {
    return "₹" + (cents / 100).toFixed(2);
  }

  function getSetSize(title) {
    for (const [key, multiplier] of Object.entries(setMultipliers)) {
      if (title.includes(key)) return multiplier;
    }
    return 1; 
  }

  function getUniqueColors() {
    let colors = new Set();
    shopifyVariants.forEach(v => {
      if (v[colorOptionKey]) colors.add(v[colorOptionKey]);
    });
    return Array.from(colors);
  }

  // --- FEATURE 3: CART-AWARE INVENTORY ---
  let cartQuantities = {};

  async function fetchCartInventory() {
    try {
      const res = await fetch('/cart.js');
      const cart = await res.json();
      cart.items.forEach(item => {
        cartQuantities[item.variant_id] = (cartQuantities[item.variant_id] || 0) + item.quantity;
      });
    } catch (e) {
      console.error("Error fetching cart data");
    }
  }

  let rowCounter = 0;

  function addAllColors() {
    const colors = getUniqueColors();
    colors.forEach(color => {
      // Check if a row for this color already exists
      const existing = [...document.querySelectorAll('.js-color-select')].find(s => s.value === color);
      if (!existing) {
        addBuilderRow(color);
      }
    });
    // Smoothly scroll down so they can see the total amount
    setTimeout(() => {
      document.getElementById('js-dynamic-rows').lastElementChild?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 100);
  }

  function quickAddColor(colorName) {
    // If a row for this color already exists, just highlight it
    const existing = [...document.querySelectorAll('.js-color-select')]
      .find(s => s.value === colorName);
    if (existing) {
      const row = existing.closest('.b-row');
      row.classList.add('b-row-flash');
      row.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      setTimeout(() => row.classList.remove('b-row-flash'), 900);
      return;
    }
    addBuilderRow(colorName);
  }

  function addBuilderRow(preselectedColor) {
    const container = document.getElementById('js-dynamic-rows');
    const emptyState = document.getElementById('js-empty-state');
    if (emptyState) emptyState.style.display = 'none';

    const rowId = 'row-' + rowCounter++;
    const colors = getUniqueColors();
    let colorOptionsHTML = colors.map(c =>
      `<option value="${c}" ${c === preselectedColor ? 'selected' : ''}>${c}</option>`
    ).join('');

    const rowHTML = `
      <div class="b-row" id="${rowId}" style="animation: rowSlideIn 0.28s cubic-bezier(0.34,1.56,0.64,1) both;">
        <div class="b-row-top">
          <div class="b-color-indicator js-color-indicator"></div>
          <div class="b-selectors">
            <select class="b-select js-color-select" onchange="handleColorChange('${rowId}')">
              ${colorOptionsHTML}
            </select>
            <select class="b-select js-size-select" onchange="calculateRowTotals('${rowId}')"></select>
          </div>
          <button class="b-delete" onclick="deleteRow('${rowId}')" title="Remove">
            <i class="fa-solid fa-trash-can"></i>
          </button>
        </div>
        <div class="b-row-bottom">
          <span class="b-info-rate js-row-rate">—</span>
          <div class="b-row-right">
            <div class="qty-wrapper">
              <button type="button" class="qty-btn" onclick="adjustQty('${rowId}', -1)"><i class="fa-solid fa-minus"></i></button>
              <input type="number" class="b-qty js-qty-input" value="1" min="1" onchange="calculateRowTotals('${rowId}')">
              <button type="button" class="qty-btn" onclick="adjustQty('${rowId}', 1)"><i class="fa-solid fa-plus"></i></button>
            </div>
            <div class="b-info-right">
              <span class="js-row-pcs b-pcs-label">— pcs</span>
              <span class="stock-badge js-row-stock"></span>
            </div>
          </div>
        </div>
      </div>
    `;

    container.insertAdjacentHTML('beforeend', rowHTML);
    handleColorChange(rowId);
  }

  function adjustQty(rowId, change) {
    const row = document.getElementById(rowId);
    const input = row.querySelector('.js-qty-input');
    let currentVal = parseInt(input.value) || 1;
    let newVal = currentVal + change;
    
    if (newVal < 1) newVal = 1; 
    input.value = newVal;
    
    calculateRowTotals(rowId);
  }

  function deleteRow(rowId) {
    const row = document.getElementById(rowId);
    if(row) {
      row.remove();
      syncGrandTotals();
    }
  }

  function handleColorChange(rowId) {
    const row = document.getElementById(rowId);
    const colorSelect = row.querySelector('.js-color-select');
    const sizeSelect = row.querySelector('.js-size-select');
    const selectedColor = colorSelect.value;

    // Paint the color indicator dot using the quick-pick button's CSS var
    const indicator = row.querySelector('.js-color-indicator');
    if (indicator) {
      const qBtn = document.querySelector(`.quick-color-btn[onclick*="${CSS.escape(selectedColor)}"]`);
      const dotColor = qBtn ? getComputedStyle(qBtn).getPropertyValue('--qc').trim() : selectedColor.toLowerCase();
      indicator.style.background = dotColor;
    }

    // Mark the quick-pick button as active
    document.querySelectorAll('.quick-color-btn').forEach(b => {
      const name = b.getAttribute('onclick').match(/'([^']+)'/)?.[1];
      b.classList.toggle('qcb-active', name === selectedColor);
    });

    let optionsHTML = '';
    shopifyVariants.forEach(v => {
      if (v[colorOptionKey] === selectedColor && v[sizeOptionKey]) {
        let rawInventory = variantInventories[v.id].qty;
        let policy = variantInventories[v.id].policy;
        let inCart = cartQuantities[v.id] || 0;
        let isOutOfStock = (policy !== 'continue' && (rawInventory - inCart) <= 0);
        if (isOutOfStock) {
           optionsHTML += `<option value="${v[sizeOptionKey]}" disabled>${v[sizeOptionKey]} (Out of Stock)</option>`;
        } else {
           optionsHTML += `<option value="${v[sizeOptionKey]}">${v[sizeOptionKey]}</option>`;
        }
      }
    });
    sizeSelect.innerHTML = optionsHTML;
    const firstAvailable = sizeSelect.querySelector('option:not([disabled])');
    if (firstAvailable) firstAvailable.selected = true;
    calculateRowTotals(rowId);
  }

  function calculateRowTotals(rowId) {
    const row = document.getElementById(rowId);
    const selectedColor = row.querySelector('.js-color-select').value;
    const selectedSize = row.querySelector('.js-size-select').value;
    const qtyInput = row.querySelector('.js-qty-input');
    
    const matchedVariant = shopifyVariants.find(v => 
      v[colorOptionKey] === selectedColor && v[sizeOptionKey] === selectedSize
    );

    if (matchedVariant) {
      let multiplier = getSetSize(matchedVariant.title);
      
      // READ INVENTORY & DEDUCT CART AMOUNTS
      let rawInventory = variantInventories[matchedVariant.id].qty;
      let inventoryPolicy = variantInventories[matchedVariant.id].policy;
      let inCart = cartQuantities[matchedVariant.id] || 0;
      
      let maxSets = Infinity;
      if (inventoryPolicy !== 'continue') {
        maxSets = rawInventory - inCart; // Subtract sets already in cart
        if (maxSets < 0) maxSets = 0;
      }

      let sets = parseInt(qtyInput.value) || 0;
      
      // Block user from exceeding stock
      if (sets > maxSets) {
        sets = maxSets;
        qtyInput.value = sets;
      }

      // Update Stock UI
      const stockBadge = row.querySelector('.js-row-stock');
      if (maxSets === 0) {
        stockBadge.innerHTML = '<span class="stock-red">OUT OF STOCK</span>';
        qtyInput.value = 0;
        qtyInput.disabled = true;
        row.querySelectorAll('.qty-btn').forEach(b => b.disabled = true);
        sets = 0;
      } else {
        qtyInput.disabled = false;
        row.querySelectorAll('.qty-btn').forEach(b => b.disabled = false);
        if (sets === 0) { qtyInput.value = 1; sets = 1; } // reset to 1 if available
        
        if (maxSets === Infinity) {
          stockBadge.innerHTML = '<span class="stock-green">IN STOCK</span>';
        } else {
          stockBadge.innerHTML = `<span class="stock-green">ONLY ${maxSets} SETS AVAILABLE</span>`;
        }
      }

      let pcs = sets * multiplier;
      qtyInput.dataset.vid = matchedVariant.id;
      qtyInput.dataset.rowTotalAmount = sets * matchedVariant.price;
      qtyInput.dataset.rowTotalPcs = pcs;

      row.querySelector('.js-row-rate').innerText = `Rate: ${formatMoney(matchedVariant.price)} / Set`;
      row.querySelector('.js-row-pcs').innerText = `${pcs} Pcs Total (1 Set = ${multiplier})`;
    } else {
      row.querySelector('.js-row-rate').innerText = "Unavailable";
      qtyInput.dataset.vid = "";
      qtyInput.dataset.rowTotalAmount = 0;
      qtyInput.dataset.rowTotalPcs = 0;
    }
    
    syncGrandTotals();
  }

  function syncGrandTotals() {
    let grandPcs = 0;
    let grandAmount = 0;
    
    document.querySelectorAll('.js-qty-input').forEach(input => {
      grandPcs += parseInt(input.dataset.rowTotalPcs) || 0;
      grandAmount += parseInt(input.dataset.rowTotalAmount) || 0;
    });
    
    document.getElementById('js-grand-pcs').innerText = grandPcs;
    document.getElementById('js-grand-amount').innerText = formatMoney(grandAmount);
  }

  async function pushBatchToShopify() {
    const btn = document.getElementById('js-add-btn');
    let items = [];
    
    document.querySelectorAll('.js-qty-input').forEach(input => {
      let sets = parseInt(input.value) || 0;
      let vid = input.dataset.vid;
      if (sets > 0 && vid) { 
        items.push({ id: vid, quantity: sets }); 
      }
    });
    
    if (items.length === 0) return alert("Please select at least 1 valid set.");
    
    btn.querySelector("span").innerText = "Adding..."; btn.disabled = true;
    try {
      await fetch('/cart/add.js', { 
        method: 'POST', 
        headers: { 'Content-Type': 'application/json' }, 
        body: JSON.stringify({ items: items }) 
      });
      
      document.documentElement.dispatchEvent(new CustomEvent('cart:change', {bubbles: true}));
      document.documentElement.dispatchEvent(new CustomEvent('cart:updated', {bubbles: true}));
      
      const cartIcon = document.querySelector('#cart-icon-bubble, .header__icon--cart, a[href="/cart"]');
      if (cartIcon && !window.location.pathname.includes('/cart')) {
        cartIcon.click();
        btn.querySelector("span").innerText = "Add to Cart"; btn.disabled = false;
      } else {
        window.location.href = '/cart';
      }
    } catch (e) { 
      alert("Error adding to cart"); 
      btn.querySelector("span").innerText = "Add to Cart"; btn.disabled = false; 
    }
  }

  // LIGHT SPEED FIX: Render instantly, fetch cart in the background
  document.addEventListener("DOMContentLoaded", function() {
    startAutoSwipe();
    addBuilderRow(); // Renders the first row instantly!
    
    // Fetch cart inventory silently in the background
    fetchCartInventory().then(() => {
      // Once cart data loads, silently refresh the dropdowns to apply any cart limits
      document.querySelectorAll('.b-row').forEach(row => {
        handleColorChange(row.id);
      });
    });
  });

/* --- ACCORDION CLICK LOGIC --- */
  function toggleAccordion(button) {
    const item = button.parentElement;
    const body = item.querySelector('.acc-body');
    const icon = item.querySelector('.acc-icon');
    const isActive = item.classList.contains('active');

    // Close all accordions
    document.querySelectorAll('.acc-item').forEach(el => {
      el.classList.remove('active');
      if (el.querySelector('.acc-body')) {
        el.querySelector('.acc-body').style.maxHeight = null;
      }
      let icn = el.querySelector('.acc-icon');
      if(icn) icn.classList.replace('fa-minus', 'fa-plus');
    });

    // Open clicked one
  if (!isActive) {
    item.classList.add('active');
    // Added a 500px buffer to safely account for dynamic line breaks and margins
    if (body) {
      body.style.maxHeight = (body.scrollHeight + 500) + "px"; 
    }
    if(icon) icon.classList.replace('fa-plus', 'fa-minus');
  }
}

  /* --- SIZE CHART MODAL LOGIC --- */
  function openSizeChart() {
    const modal = document.getElementById('sizeChartModal');
    modal.style.display = 'flex';
    setTimeout(() => modal.classList.add('show'), 10);
  }

  function closeSizeChart() {
    const modal = document.getElementById('sizeChartModal');
    modal.classList.remove('show');
    setTimeout(() => modal.style.display = 'none', 300);
  }

  function switchSizeTab(tabId, btn) {
    document.querySelectorAll('.size-tab-content').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.size-tab').forEach(el => el.classList.remove('active'));
    document.getElementById('tab-' + tabId).classList.add('active');
    btn.classList.add('active');
  }

  // Close modal when clicking on the dark background overlay
  window.onclick = function(event) {
    const modal = document.getElementById('sizeChartModal');
    if (event.target === modal) {
      closeSizeChart();
    }
  }

/* --- OFFERS AUTO-SWIPE & MANUAL LOGIC --- */
  document.addEventListener("DOMContentLoaded", function() {
    const track = document.getElementById('offersTrack');
    if (!track) return;

    let offerIndex = 0;
    // Pulls swipe speed from theme editor, converts seconds to milliseconds
    const offerSwipeSpeed = {{ section.settings.offer_swipe_speed | default: 4 }} * 1000; 
    let offerInterval;

    function startOfferSwipe() {
      clearInterval(offerInterval);
      offerInterval = setInterval(() => {
        const cards = track.querySelectorAll('.offer-card');
        if (cards.length <= 1) return; // Don't swipe if there's only 1 offer
        
        // Find the card currently closest to the left edge to sync with manual scrolling
        let closestIndex = 0;
        let minDistance = Infinity;
        cards.forEach((card, index) => {
          let dist = Math.abs((card.offsetLeft - track.offsetLeft) - track.scrollLeft);
          if (dist < minDistance) {
             minDistance = dist;
             closestIndex = index;
          }
        });
        
        // Move to the next index, loop back to 0 if at the end
        offerIndex = (closestIndex + 1) % cards.length;
        const scrollPosition = cards[offerIndex].offsetLeft - track.offsetLeft;
        
        // Smoothly scroll to the next card
        track.scrollTo({ left: scrollPosition, behavior: 'smooth' });
      }, offerSwipeSpeed);
    }

    // Start immediately
    startOfferSwipe();

    // Pause auto-swipe while user is manually scrolling/touching
    track.addEventListener('mouseenter', () => clearInterval(offerInterval));
    track.addEventListener('mouseleave', startOfferSwipe);
    track.addEventListener('touchstart', () => clearInterval(offerInterval), {passive: true});
    track.addEventListener('touchend', () => {
      setTimeout(startOfferSwipe, 2000); // Resume auto-swipe 2 seconds after user lets go
    }, {passive: true});
  });
</script>

<script>
function toggleAccordion(btn) {
  // 1. Find the parent item
  const item = btn.parentElement;
  const icon = btn.querySelector('.acc-icon');
  const body = btn.nextElementSibling;

  // 2. Toggle the "active" class on the item
  const isActive = item.classList.contains('active');

  // 3. Update the icon and height
  if (isActive) {
    item.classList.remove('active');
    icon.classList.replace('fa-minus', 'fa-plus');
    body.style.maxHeight = null;
  } else {
    item.classList.add('active');
    icon.classList.replace('fa-plus', 'fa-minus');
    body.style.maxHeight = body.scrollHeight + "px";
  }
}
</script>

