<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  #shopify-section-{{ section.id }} {
    --navy: {{ section.settings.heading_color }};
    --gold-main: {{ section.settings.accent_color }};
    --border: {{ section.settings.border_color }};
    --bg-white: {{ section.settings.bg_color }};
    --card-bg: {{ section.settings.card_bg_color }};
    --text-muted: {{ section.settings.text_color }};
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  /* --- ANIMATION --- */
  #shopify-section-{{ section.id }} .reveal-up {
    opacity: 0;
    transform: translateY(50px) translateZ(-50px) rotateX(-5deg);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #shopify-section-{{ section.id }} .reveal-up.active {
    opacity: 1;
    transform: translateY(0) translateZ(0) rotateX(0deg);
  }

  /* --- PAYMENT SECTION --- */
  #shopify-section-{{ section.id }} .payment-section {
    padding: {{ section.settings.padding_top }}px 5% {{ section.settings.padding_bottom }}px;
    background: var(--bg-white);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  #shopify-section-{{ section.id }} .payment-subheading {
    color: var(--gold-main); 
    letter-spacing: 2px; 
    font-weight: 800;
    margin: 0;
    font-size: 0.85rem;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .payment-heading {
    font-size: 2.5rem; 
    font-weight: 900; 
    margin: 10px 0; 
    color: var(--navy);
  }

  #shopify-section-{{ section.id }} .payment-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 40px;
  }

  #shopify-section-{{ section.id }} .pay-card {
    background: var(--card-bg);
    padding: 25px;
    border-radius: 15px;
    border: 1px solid var(--border);
    text-align: center;
    box-shadow: 0 5px 15px rgba(0,0,0,0.03);
  }

  #shopify-section-{{ section.id }} .pay-icon { 
    font-size: 2rem; 
    color: var(--gold-main); 
    margin-bottom: 15px; 
  }

  #shopify-section-{{ section.id }} .pay-title { 
    font-weight: 800; 
    color: var(--navy); 
    margin-bottom: 5px; 
    font-size: 1rem; 
  }

  #shopify-section-{{ section.id }} .pay-desc { 
    font-size: 0.85rem; 
    color: var(--text-muted); 
    line-height: 1.4; 
    margin: 0;
  }

  /* --- MOBILE OPTIMIZATION --- */
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .payment-section { 
      padding-top: {{ section.settings.padding_top_mobile }}px !important; 
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important; 
    }
    #shopify-section-{{ section.id }} .payment-heading { 
      margin: 15px 0 25px !important; 
    }
    #shopify-section-{{ section.id }} .payment-grid { 
      grid-template-columns: repeat(2, 1fr) !important; 
      gap: 10px; 
      padding-left: 10px; 
      padding-right: 10px;
    }
    #shopify-section-{{ section.id }} .pay-card { 
      padding: 15px; 
    }
    #shopify-section-{{ section.id }} .pay-icon { 
      font-size: 1.5rem; 
      margin-bottom: 10px; 
    }
    #shopify-section-{{ section.id }} .pay-title { 
      font-size: 0.75rem !important; 
      margin-bottom: 5px; 
    }
    #shopify-section-{{ section.id }} .pay-desc { 
      font-size: 0.65rem !important; 
      line-height: 1.2; 
    }
  }
</style>

<section class="payment-section" id="payment-{{ section.id }}">
  <div class="reveal-up" style="text-align: center;">
    <h6 class="payment-subheading">{{ section.settings.subheading }}</h6>
    <h2 class="payment-heading">{{ section.settings.heading }}</h2>
  </div>
  
  <div class="payment-grid">
    {%- for block in section.blocks -%}
      {%- assign delay = forloop.index0 | times: 0.2 -%}
      <div class="pay-card reveal-up" style="transition-delay: {{ delay }}s;" {{ block.shopify_attributes }}>
        <div class="pay-icon"><i class="{{ block.settings.icon_class }}"></i></div>
        <div class="pay-title">{{ block.settings.title }}</div>
        <div class="pay-desc">{{ block.settings.description }}</div>
      </div>
    {%- endfor -%}
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.2 });
    
    const elements = document.querySelectorAll('#payment-{{ section.id }} .reveal-up');
    elements.forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Espon Payment",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "FLEXIBLE B2B PAYMENTS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PAYMENT TERMS"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Gold)",
      "default": "#CA8A04"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color (Navy)",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Paragraph Text Color",
      "default": "#64748b"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#e2e8f0"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "payment_card",
      "name": "Payment Method",
      "settings": [
        {
          "type": "text",
          "id": "icon_class",
          "label": "FontAwesome Icon Class",
          "default": "fas fa-money-bill-wave"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Payment Method"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Payment description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Espon Payment",
      "blocks": [
        {
          "type": "payment_card",
          "settings": {
            "icon_class": "fas fa-money-bill-wave",
            "title": "Cash on Delivery (COD)",
            "description": "Pay just 10% Advance. Balance on delivery."
          }
        },
        {
          "type": "payment_card",
          "settings": {
            "icon_class": "fas fa-credit-card",
            "title": "Credit Card",
            "description": "Up to 50 days interest-free credit period."
          }
        },
        {
          "type": "payment_card",
          "settings": {
            "icon_class": "fas fa-university",
            "title": "Prepaid Options",
            "description": "Bank Transfer, NEFT/RTGS."
          }
        },
        {
          "type": "payment_card",
          "settings": {
            "icon_class": "fas fa-file-invoice",
            "title": "GST Invoice",
            "description": "GST @ 5% applicable. Input credit available."
          }
        }
      ]
    }
  ]
}
{% endschema %}