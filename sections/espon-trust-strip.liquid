<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  #shopify-section-{{ section.id }} {
    --bg-white: {{ section.settings.bg_color }};
    --border: {{ section.settings.border_color }};
    --navy: {{ section.settings.heading_color }};
    --gold-main: {{ section.settings.icon_color }};
    --text-muted: {{ section.settings.desc_color }};
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  /* --- ANIMATION --- */
  #shopify-section-{{ section.id }} .reveal-up {
    opacity: 0;
    transform: translateY(50px) translateZ(-50px) rotateX(-5deg);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #shopify-section-{{ section.id }} .reveal-up.active {
    opacity: 1;
    transform: translateY(0) translateZ(0) rotateX(0deg);
  }

  #shopify-section-{{ section.id }} .trust-strip {
    background: var(--bg-white);
    border-bottom: 1px solid var(--border);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 20px;
    padding: {{ section.settings.padding_top }}px 5% {{ section.settings.padding_bottom }}px;
    text-align: center;
  }
  
  #shopify-section-{{ section.id }} .trust-icon { 
    font-size: 2rem; 
    color: var(--gold-main); 
    margin-bottom: 10px; 
  }
  
  #shopify-section-{{ section.id }} .trust-text h4 { 
    font-size: 0.9rem; 
    margin: 0; 
    font-weight: 800; 
    color: var(--navy); 
  }
  
  #shopify-section-{{ section.id }} .trust-text p { 
    font-size: 0.75rem; 
    color: var(--text-muted); 
    margin: 0; 
  }

  /* --- MOBILE OPTIMIZATION --- */
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .trust-strip {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 10px;
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
      padding-left: 10px !important;
      padding-right: 10px !important;
    }
  }
</style>

<div class="trust-strip reveal-up" id="trust-strip-{{ section.id }}">
  {%- for block in section.blocks -%}
    <div {{ block.shopify_attributes }}>
      <div class="trust-icon"><i class="{{ block.settings.icon_class }}"></i></div>
      <div class="trust-text">
        <h4>{{ block.settings.title }}</h4>
        <p>{{ block.settings.description }}</p>
      </div>
    </div>
  {%- endfor -%}
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.3 });
    
    const element = document.getElementById('trust-strip-{{ section.id }}');
    if (element) {
      observer.observe(element);
    }
  });
</script>

